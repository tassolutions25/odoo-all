<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ahadu_hr.StructuralOrgChart" owl="1">
        <div class="o_structural_chart_container d-flex flex-column">
            <!-- Filter Bar -->
            <div class="o_structural_chart_filter_bar flex-shrink-0">
                <h5 class="filter_label"><i class="fa fa-filter me-2"/>Filters</h5>
                <div class="filter_controls">
                    <select class="form-select" name="department_id" disabled="true">
                        <option value="all">All Departments</option>
                    </select>
                    <select class="form-select" name="job_id" disabled="true">
                        <option value="all">All Job Positions</option>
                    </select>
                </div>
                <button class="btn btn-secondary ms-2" disabled="true">
                    <i class="fa fa-undo me-1"/> Reset
                </button>
            </div>

            <!-- Chart Area -->
            <div class="flex-grow-1 overflow-auto">
                <div t-if="state.loading" class="o_loading_indicator text-center py-5">
                    <i class="fa fa-spinner fa-spin fa-3x text-muted"/>
                    <p class="mt-3">Loading Structural Chart...</p>
                </div>
                <div t-elif="!state.hierarchyData.length" class="text-center py-5">
                    <i class="fa fa-sitemap fa-3x text-muted"/>
                    <h4 class="mt-3">No Chart Structure Found</h4>
                    <p>Please ensure the organogram structure is defined in HR Configuration.</p>
                </div>
                <div t-else="" class="o_structural_chart">
                    <ul>
                        <t t-foreach="state.hierarchyData" t-as="node" t-key="node.id">
                            <StructuralOrgChartNode node="node" onToggle="toggleNode"/>
                        </t>
                    </ul>
                </div>
            </div>
        </div>
    </t>

    <!-- Recursive Node Template -->
    <t t-name="ahadu_hr.StructuralOrgChart.Node" owl="1">
        <li>
            <div class="o_structural_node_card">
                <div class="card_main_content">
                    <img class="card_image" t-att-src="props.node.imageUrl" alt="Avatar"/>
                    <div class="card_details">
                        <div class="card_name" t-esc="props.node.name"/>
                        <div class="card_position" t-esc="props.node.job_title"/>
                    </div>
                </div>
                <div t-if="props.node.children.length > 0" class="card_toggle_container">
                    <button class="card_toggle_button" t-on-click="() => props.onToggle(props.node)">
                        <span class="toggle_count" t-esc="props.node.subordinates_count"/>
                        <i class="fa fa-users toggle_icon" aria-hidden="true"/>
                        <i t-att-class="props.node.is_expanded ? 'fa fa-chevron-up toggle_chevron' : 'fa fa-chevron-down toggle_chevron'"/>
                    </button>
                </div>
            </div>
            <ul t-if="props.node.is_expanded and props.node.children.length > 0">
                <t t-foreach="props.node.children" t-as="childNode" t-key="childNode.id">
                    <StructuralOrgChartNode node="childNode" onToggle="props.onToggle"/>
                </t>
            </ul>
        </li>
    </t>

</templates>