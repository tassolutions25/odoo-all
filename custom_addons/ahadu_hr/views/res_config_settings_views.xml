<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_ahadu_hr" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ahadu.hr</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr.res_config_settings_view_form"/>
        <field name="arch" type="xml">
        <xpath expr="//form" position="inside">
                <h2>Ahadu HR Allowances</h2>
                <div class="row mt16 ml16 o_settings_container" id="ahadu_hr_allowance_settings">
                    <div class="col-12 col-lg-12 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="fuel_price_cutoff_date"/>
                            <div class="text-muted">
                                Set the payroll processing cutoff date. Adjustments for price changes after this date in the previous month will be added to the current month.
                            </div>
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="fuel_price_cutoff_date" class="oe_inline"/>
                                </div>
                            </div>
                        </div>

                        <div class="o_setting_right_pane">
                            <label for="fuel_price_history_ids" string="Fuel Price History"/>
                            <div class="text-muted">
                                Manage the history of fuel prices per liter. The most recent effective price will be used for calculations.
                            </div>
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="fuel_price_history_ids" class="w-100" context="{'tree_view_ref': 'ahadu_hr.view_ahadu_fuel_price_history_tree'}"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
        </xpath>
        </field>
    </record>
</odoo>