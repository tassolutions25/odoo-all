<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_temporary_assignment_form" model="ir.ui.view">
        <field name="name">hr.employee.temporary.assignment.form</field>
        <field name="model">hr.employee.temporary.assignment</field>
        <field name="arch" type="xml">
            <form string="Temporary Assignment">
                <header>
                     <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve_step" string="Approve" type="object" class="btn-success" invisible="can_approve == False"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="can_approve == False"/>
                    <button name="action_draft" string="Reset to Draft" type="object" class="oe_link" invisible="state not in ('submitted', 'rejected')" groups="hr.group_hr_user"/>
                    <button name="action_cancel" string="Cancel Assignment" type="object" invisible="state not in ['approved', 'submitted']"
                            confirm="Are you sure you want to cancel this assignment? This will revert the employee's details if the assignment is active."/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,completed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                         <h1>
                            <field name="employee_id" placeholder="Employee's Name" invisible="1"/>
                            <span invisible="[('employee_id', '=', False)]">Assignment for <field name="employee_id" readonly="1" options="{'no_open': True}"/></span>
                            <span invisible="[('employee_id', '!=', False)]">New Temporary Assignment</span>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_number_search" placeholder="e.g. AHB1234"/>
                            <field name="employee_id" invisible="state != 'draft'"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                           <field name="next_approver_ids" widget="many2many_tags" readonly="1" invisible="state != 'submitted'"/>
                           <field name="can_approve" invisible="1"/>
                        </group>
                    </group>

                    <div class="row">
                        <div class="col-md-6">
                            <group string="Current Information">
                                <field name="current_department_id"/>
                                <field name="current_division_id"/>
                                <field name="current_branch_id"/>
                                <field name="current_cost_center_id"/>
                                <field name="current_parent_id"/>
                            </group>
                        </div>
                        <div class="col-md-6">
                            <group string="New Assignment Details">
                                <field name="new_department_id" options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="new_division_id" options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="new_branch_id" options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="new_cost_center_id" options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="new_parent_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            </group>
                        </div>
                    </div>
                    
                    <group string="Original Details (At time of Approval)" invisible="state in ['draft', 'submitted']">
                         <field name="original_department_id"/>
                         <field name="original_division_id"/>
                         <field name="original_branch_id"/>
                         <field name="original_cost_center_id"/>
                         <field name="original_parent_id"/>
                    </group>
                    
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Add any relevant details or reasons for the assignment here..."/>
                        </page>
                         <page string="Approval History" name="approval_history">
                            <field name="approval_line_ids" readonly="1">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="approver_id"/>
                                    <field name="status"/>
                                    <field name="approval_date"/>
                                    <field name="comments"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_employee_temporary_assignment_tree" model="ir.ui.view">
        <field name="name">hr.employee.temporary.assignment.tree</field>
        <field name="model">hr.employee.temporary.assignment</field>
        <field name="arch" type="xml">
            <list string="Temporary Assignments">
                <field name="employee_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="new_department_id"/>
                <field name="new_branch_id"/>
                <field name="state" widget="badge" decoration-info="state=='submitted'" decoration-success="state in ('approved', 'completed')" decoration-danger="state in ('rejected', 'cancelled')"/>
            </list>
        </field>
    </record>


    <record id="view_hr_employee_temporary_assignment_search" model="ir.ui.view">
        <field name="name">hr.employee.temporary.assignment.search</field>
        <field name="model">hr.employee.temporary.assignment</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="new_department_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_employee_temporary_assignment" model="ir.actions.act_window">
        <field name="name">Temporary Assignments</field>
        <field name="res_model">hr.employee.temporary.assignment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_employee_temporary_assignment_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new temporary assignment for an employee.
            </p>
        </field>
    </record>
</odoo>