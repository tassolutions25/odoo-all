<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_acting_form" model="ir.ui.view">
        <field name="name">hr.employee.acting.form</field>
        <field name="model">hr.employee.acting</field>
        <field name="arch" type="xml">
            <form string="Acting Assignment">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve_step" string="Approve" type="object" class="btn-success" invisible="can_approve == False"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="can_approve == False"/>
                    <button name="action_draft" string="Reset to Draft" type="object" class="oe_link" invisible="state not in ('submitted', 'rejected')" groups="hr.group_hr_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Acting Assignment</h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_number_search" placeholder="e.g. AHB1234"/>
                            <field name="employee_id"/>
                            <field name="acting_job_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="next_approver_ids" widget="many2many_tags" readonly="1" invisible="state != 'submitted'"/>
                            <field name="can_approve" invisible="1"/>
                        </group>
                    </group>
                    <div class="row">
                        <div class="col-md-6">
                            <group string="Current Information">
                                <field name="current_department_id"/>
                                <field name="current_branch_id"/>
                            </group>
                        </div>
                        <div class="col-md-6">
                            <group string="New Assignment Details">
                                <field name="new_department_id"/>
                                <field name="new_branch_id"/>
                            </group>
                        </div>
                    </div>
                    
                    <group string="Original Details (At time of Approval)" invisible="[('state', 'in', ['draft', 'submitted'])]">
                         <field name="original_department_id" readonly="1"/>
                         <field name="original_branch_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="reason" placeholder="Reason for the acting assignment..."/>
                    </group>
                    <group string="Attachments">
                        <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="approval_line_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="approver_id"/>
                                    <field name="status"/>
                                    <field name="approval_date"/>
                                    <field name="comments"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_acting_tree" model="ir.ui.view">
        <field name="name">hr.employee.acting.tree</field>
        <field name="model">hr.employee.acting</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="acting_job_id"/>
                <field name="start_date"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'" decoration-warning="state == 'submitted'" decoration-info="state == 'completed'"/>
            </list>
        </field>
    </record>

    <record id="action_employee_acting" model="ir.actions.act_window">
        <field name="name">Acting Assignments</field>
        <field name="res_model">hr.employee.acting</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>