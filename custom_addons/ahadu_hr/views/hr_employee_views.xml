<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_employee_form_inherit_benefits" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.benefits</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form" />
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Benefits &amp; Allowances" name="benefits_allowances">
                        <group>
                            <group string="Fixed Allowances">
                                <field name="housing_allowance" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="mobile_allowance" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="representation_allowance" />
                                <field name="hardship_allowance_level_id" />
                            </group>
                            <group string="Transport Allowance">
                                <field name="transport_allowance_liters" />
                                <field name="transport_allowance_amount" force_save="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
        <record id="view_employee_tree_inherit_archived" model="ir.ui.view">
            <field name="name">hr.employee.tree.archived.ahadu</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="departure_type" widget="badge" 
                        decoration-danger="departure_type == 'termination'" 
                        decoration-warning="departure_type == 'resignation'"
                        decoration-info="departure_type == 'retirement'"
                        invisible="active == True"/>
                </xpath>
            </field>
        </record>
        <record id="view_employee_form_extended" model="ir.ui.view">
            <field name="name">hr.employee.form.extended</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form" />
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_view_suspensions" string="Suspension Management" 
                            type="object" groups="hr.group_hr_manager" class="btn-warning"/>
                </xpath>
                <xpath expr="//sheet" position="before">
                <field name="ahadu_state" widget="badge" 
                        decoration-success="ahadu_state == 'active'" 
                        decoration-danger="ahadu_state == 'suspended'"
                        style="margin-left: 10px;"/>
                    <header>
                        <button name="action_submit" string="Submit for Approval" type="object"
                            class="btn-primary" invisible="state != 'draft'" />
                        <button name="action_approve_step" string="Approve" type="object"
                            class="btn-success" invisible="can_approve == False" />
                        <button name="action_reject" string="Reject" type="object"
                            class="btn-danger" invisible="can_approve == False" />
                        <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state not in ['rejected']" />
                        <field name="state" widget="statusbar"
                            statusbar_visible="draft,submitted,approved,rejected" />
                    </header>
                </xpath>     
                
                <xpath expr="//field[@name='name']" position="replace">
                    <field name="name" invisible="1" />
                    <div class="oe_title">
                        <label for="employee_id" class="oe_edit_only" />
                        <h2>
                            <field name="employee_id" required="1" placeholder="e.g., AHB1234" />
                        </h2>
                        <h4>
                            <group>
                                <group>
                                    <field name="salutation" />
                                    <field name="first_name" required="1" />
                                </group>
                                <group>
                                    <field name="middle_name" required="1" />
                                    <field name="last_name" required="1" />
                                </group>
                            </group>
                        </h4>
                    </div>
                </xpath>  
                <xpath expr="//div[hasclass('oe_button_box')]" position="after">
                    <group invisible="state == 'draft'">
                        <group>
                            <field name="next_approver_ids" widget="many2many_tags" readonly="1" />
                            <field name="can_approve" invisible="1" />
                        </group>
                        <group />
                    </group>
                </xpath>
                <xpath expr="//page[@name='public']//group[1]" position="after">
                    <group string="Guarantor Information (at time of hiring)">
                        <field name="guarantor_name" />
                        <field name="guarantor_company" />
                        <field name="guarantor_commitment_amount" widget="monetary"
                            options="{'currency_field': 'currency_id'}" />
                        <field name="currency_id" invisible="1" />
                        <field name="guarantee_letter" widget="binary"
                            filename="guarantee_letter_filename" />
                    </group>
                </xpath>

                <xpath expr="//field[@name='passport_id']" position="after">
                    <field name="gender_updated" widget="radio" options="{'horizontal': true}" />
                </xpath>

                <xpath expr="//field[@name='gender']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='work_email']" position="after">
                    <field name="private_email" widget="email" />
                </xpath>


                <xpath expr="//group[.//field[@name='job_id']]" position="after">
                    <group string="Job Details">
                        <field name="date_of_joining" />
                        <field name="position_classification" />
                        <field name="ahadu_employee_type_id" readonly="1" force_save="1"/>
                        <field name="grade_id" />
                        <!-- <field name="representation_allowance" />
                        <field name="hardship_allowance_level_id" /> -->
                        <field name="emp_wage" />
                        <field name="is_acting" invisible="1" />
                        <field name="acting_job_id" invisible="is_acting == False" readonly="1" />
                    </group>
                </xpath>


                <xpath expr="//field[@name='department_id']" position="after">
                    <field name="branch_id" />
                    <field name="division_id" context="{'default_department_id': department_id}" />
                    <field name="region_id" options="{'no_create': True}" />
                    <field name="city_id" options="{'no_create': True}" />
                    <field name="district_id" />

                </xpath>

                <xpath expr="//field[@name='identification_id']" position="after">
                    <field name="kebele_id" />
                    <field name="tin_number" required="1" />

                </xpath>
                <xpath expr="//field[@name='private_country_id']" position="after">
                    <field name="subcity" placeholder="Subcity" />
                    <field name="woreda" placeholder="Woreda" />
                    <field name="house_number" placeholder="House Number" />
                </xpath>
                <xpath expr="//field[@name='birthday']" position="after">
                    <field name="birthday_et" />
                </xpath>


                <xpath expr="//notebook" position="inside">
                    <page string="Education and Training" name="education_and_training">
                        <group string="Education History">
                            <field name="education_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="type_of_institution" required="1" />
                                    <field name="school" required="1" />
                                    <field name="certificate_level" required="1" />
                                    <field name="field_of_study" required="1" />
                                    <field name="cgpa" required="1" />
                                    <field name="start_date" required="1" />
                                    <field name="end_date" required="1" />
                                    <field name="certification_attachment" widget="binary"
                                        filename="certification_filename" required="1" />
                                    <field name="certification_filename" invisible="1" />
                                </list>
                            </field>
                        </group>
                        <separator string="Training History" />
                        <group>
                            <field name="training_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="name" />
                                    <field name="trainer_company" />
                                    <field name="start_date" />
                                    <field name="end_date" />
                                    <field name="certification_attachment" widget="binary"
                                        filename="certification_filename" />
                                    <field name="certification_filename" invisible="1" />
                                </list>
                            </field>
                        </group>
                    </page>

                </xpath>
                <xpath expr="//field[@name='parent_id']" position="attributes">
            <attribute name="context">{'show_manager_with_id': True}</attribute>
        </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="Bank Details" name="bank_details">
                        <field name="bank_account_ids">
                            <list editable="bottom">
                                <field name="bank_id" />
                                <field name="bank_country_id" optional="hide" />
                                <field name="account_number" />
                                <field name="account_holder_name" />
                                <field name="account_type" />
                                <field name="balance" invisible="account_type != 'cash_indemnity'" />
                                <field name="currency_id" optional="show" />
                            </list>
                            <form>
                                <group>
                                    <group>
                                        <field name="bank_id" />
                                        <field name="account_number" />
                                        <field name="account_holder_name" />
                                    </group>
                                    <group>
                                        <field name="account_type" />
                                        <field name="balance"
                                            invisible="account_type != 'cash_indemnity'" />
                                        <field name="bank_country_id" />
                                        <field name="currency_id" />
                                    </group>
                                </group>
                            </form>
                        </field>
                    </page>
                </xpath>

                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_suspensions" type="object" class="oe_stat_button" icon="fa-ban">
                        <field name="suspension_count" widget="statinfo" string="Suspensions"/>
                    </button>
                    <button name="action_view_activities" type="object" class="oe_stat_button"
                        icon="fa-tasks">
                        <field name="total_activities" widget="statinfo" string="Activities" />
                    </button>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="Activities" name="activities">
                        <group>
                            <group>
                                <field name="total_activities" readonly="1" />
                                <field name="pending_activities" readonly="1" />
                            </group>
                        </group>
                        <field name="ahadu_activity_ids" readonly="1"
                            context="{'view_mode': 'list', 'tree_view_ref': 'ahadu_hr.view_employee_activity_tree_in_form'}" />
                    </page>
                    <page string="Approval History" name="approval_history">
                        <field name="approval_line_ids" readonly="1">
                            <list>
                                <field name="sequence" widget="handle" />
                                <field name="approver_id" />
                                <field name="status" />
                                <field name="approval_date" />
                                <field name="comments" />
                            </list>
                        </field>
                    </page>
                </xpath>

                <xpath expr="//field[@name='grade_id']" position="after">
                    <field name="cost_center_id" />
                </xpath>

                <xpath expr="//field[@name='job_title']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='coach_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//field[@name='work_location_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//label[@for='distance_home_work']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//div[hasclass('o_row')][field[@name='distance_home_work']]"
                    position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='private_car_plate']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='certificate']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='study_field']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='study_school']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='visa_no']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='permit_no']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='visa_expire']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='work_permit_expiration_date']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='work_permit_name']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='has_work_permit']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='private_phone']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>
