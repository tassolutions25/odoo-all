        <record id="view_hr_employee_family_tree_in_form" model="ir.ui.view">
            <field name="name">hr.employee.family.list.in.form</field>
            <field name="model">hr.employee.family</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="relationship" />
                    <field name="full_name" />
                    <field name="contact_number" />
                    <field name="gender" />
                    <field name="nationality_id" />
                    <field name="dependent" />
                    <field name="insured" />
                </list>
            </field>
        </record>
        <record id="view_employee_form_extended_onboarding_fields" model="ir.ui.view">
            <field name="name">hr.employee.form.onboarding.fields</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="ahadu_hr.view_employee_form_extended" />
            <field name="arch" type="xml">

                <xpath expr="//field[@name='country_of_birth']" position="after">
                    <field name="nationality_id" />
                    <field name="wedding_date" invisible="[('marital', '!=', 'married')]" />
                    <field name="language_ids" widget="many2many_tags" />
                    <field name="blood_group" />
                    <field name="physical_challenge" />
                    <field name="physical_challenge_detail"
                        invisible="[('physical_challenge', '!=', 'yes')]" />
                </xpath>
                <xpath expr="//field[@name='kebele_id']" position="after">
                    <field name="national_id_file" widget="binary" filename="national_id_filename" />
                    <field name="national_id_filename" invisible="1" />
                    <field name="kebele_id_file" widget="binary" filename="kebele_id_filename" />
                    <field name="kebele_id_filename" invisible="1" />
                </xpath>

                <xpath expr="//field[@name='house_number']" position="after">
                    <group string="Permanent Address">
                        <field name="permanent_address_city" />
                        <field name="permanent_address_country_id" />
                    </group>
                </xpath>

                <xpath expr="//group[@name='emergency']" position="replace">
                    <group name="emergency" string="Emergency Contact">
                        <field name="emergency_contact_name" />
                        <field name="emergency_contact_relationship" />
                        <field name="emergency_contact_phone" />
                        <label for="emergency_contact_address_city" string="Address" />
                        <div class="o_address_format">
                            <field name="emergency_contact_address_city" placeholder="City"
                                class="o_address_city" />
                            <field name="emergency_contact_address_country_id" placeholder="Country"
                                class="o_address_country" options='{"no_open": True}' />
                        </div>
                    </group>
                </xpath>

                <xpath expr="//notebook" position="inside">

                    <page string="Family Details" name="family_details">
                        <field name="family_ids"
                            context="{'tree_view_ref': 'ahadu_hr.view_hr_employee_family_tree_in_form'}" />
                    </page>
                    <page string="Passport Details" name="passport_details">
                        <group>
                            <group>
                                <field name="passport_name" />
                                <field name="passport_id" string="Passport Number" />
                                <field name="passport_issue_place" />
                                <field name="encr_required" />
                            </group>
                            <group>
                                <field name="passport_issue_date" />
                                <field name="passport_expiry_date" />
                                <field name="passport_file" widget="binary"
                                    filename="passport_filename" />
                                <field name="passport_filename" invisible="1" />
                            </group>
                        </group>
                    </page>

                    <page string="Cost-Sharing Details" name="cost_sharing_details">
                        <group>
                            <group>
                                <field name="cost_sharing_institution" />
                                <field name="cost_sharing_status" />
                                <field name="cost_sharing_amount" />
                            </group>
                            <group>
                                <field name="cost_sharing_document" widget="binary"
                                    filename="cost_sharing_document_filename" />
                                <field name="cost_sharing_document_filename" invisible="1" />
                            </group>
                        </group>
                    </page>

                </xpath>

            </field>
        </record>

        <record id="view_employee_dashboard" model="ir.ui.view">
            <field name="name">hr.employee.dashboard</field>
            <field name="model">hr.employee</field>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <form string="Employee Dashboard" class="o_employee_dashboard" create="false"
                    edit="false">
                    <header>
                        <div class="oe_title">
                            <h1>Employee Dashboard</h1>
                        </div>
                    </header>
                    <sheet>
                        <div class="o_employee_dashboard_main">
                            <div class="row">
                                <div class="col-md-9">
                                    <div class="o_employee_info">
                                        <h2>
                                            <field name="name" readonly="1" />
                                        </h2>
                                        <div class="o_employee_details">
                                            <div class="row">
                                                <div class="col-md-6">
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <span class="o_form_label">Email:</span>
                                                    <field name="work_email" readonly="1" />
                                                </div>
                                                <div class="col-md-6">
                                                    <span class="o_form_label">Phone:</span>
                                                    <field name="work_phone" readonly="1" />
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <span class="o_form_label">Work Unit:</span>
                                                    <field name="department_id" readonly="1" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row mt-4">
                                <div class="col-md-3">
                                    <div class="card text-center">
                                        <div class="card-body">
                                            <i class="fa fa-bell fa-2x text-warning"></i>
                                            <h4>41</h4>
                                            <p>Unread Notifications</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_employee_filter_inherit_ahadu" model="ir.ui.view">
            <field name="name">hr.employee.search.inherit.ahadu</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_filter"/>
            <field name="arch" type="xml">
                <field name="name" position="replace">
                    <field name="name" string="Employee" 
                        filter_domain="['|', '|', ('work_email', 'ilike', self), ('name', 'ilike', self), ('employee_id', 'ilike', self)]"/>
                </field>
                
                <field name="job_id" position="after">
                    <field name="employee_id"/>
                </field>
            </field>
        </record>

        <record id="hr_kanban_view_employees_inherit_ahadu_id" model="ir.ui.view">
            <field name="name">hr.employee.kanban.inherit.ahadu.id</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.hr_kanban_view_employees"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="before">
                    <field name="employee_id"/>
                </xpath>
                
                <xpath expr="//field[@name='name']" position="before">
                    <div t-if="record.employee_id.raw_value" class="fw-bold text-primary mb-1">
                        <i class="fa fa-id-badge me-1"/> <field name="employee_id"/>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="view_employee_tree_inherit_ahadu_id" model="ir.ui.view">
            <field name="name">hr.employee.tree.inherit.ahadu.id</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="before">
                    <field name="employee_id" optional="show" decoration-bf="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>