<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_employee_probation_form" model="ir.ui.view">
            <field name="name">hr.employee.probation.form</field>
            <field name="model">hr.employee.probation</field>
            <field name="arch" type="xml">
                <form string="Probation Review">
                    <header>
                        <button name="action_submit" string="Submit for Approval" type="object" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_approve_step" string="Approve" type="object" class="btn-success" invisible="can_approve == False"/>
                        <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="can_approve == False"/>
                        <button name="action_draft" string="Reset to Draft" type="object" class="oe_link" invisible="state not in ('submitted', 'rejected')" groups="hr.group_hr_user"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                    </header>
                    
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="employee_id"/>
                                <field name="probation_end_date"/>
                            </group>
                            <group>
                                <field name="next_approver_ids" widget="many2many_tags" readonly="1" invisible="state != 'submitted'"/>
                                <field name="can_approve" invisible="1"/>
                            </group>
                        </group>
                        <group string="Recommendation">
                            <field name="recommendation"/>
                            <field name="extended_end_date" invisible="recommendation != 'extend'"/>
                            <field name="comments" placeholder="Justification for the recommendation..."/>
                        </group>
                        <notebook>
                            <page string="Approval History">
                                <field name="approval_line_ids" readonly="1">
                                <list>
                                        <field name="sequence" widget="handle"/>
                                        <field name="approver_id"/>
                                        <field name="status"/>
                                        <field name="approval_date"/>
                                        <field name="comments"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>                    
                </form>
            </field>
        </record>

        <record id="view_employee_probation_tree" model="ir.ui.view">
            <field name="name">hr.employee.probation.tree</field>
            <field name="model">hr.employee.probation</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="probation_end_date"/>
                    <field name="recommendation"/>
                    <field name="state" widget="badge" decoration-success="state == 'approved'" decoration-warning="state == 'submitted'"/>
                </list>
            </field>
        </record>

        <record id="action_employee_probation" model="ir.actions.act_window">
            <field name="name">Probation Reviews</field>
            <field name="res_model">hr.employee.probation</field>
            <field name="view_mode">list,kanban,form,graph</field>
        </record>


    </data>
</odoo>