<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_organogram_node_tree" model="ir.ui.view">
        <field name="name">hr.organogram.node.tree</field>
        <field name="model">hr.organogram.node</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="job_id"/>
                <field name="parent_id"/>
                <field name="node_type"/>
            </list>
        </field>
    </record>

    <record id="view_hr_organogram_node_form" model="ir.ui.view">
        <field name="name">hr.organogram.node.form</field>
        <field name="model">hr.organogram.node</field>
        <field name="arch" type="xml">
            <form string="Organogram Node">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g., Chief Executive Officer"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="parent_id"/>
                            <field name="job_id"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="node_type"/>
                            <field name="is_district_head"/>
                            <field name="district_id" invisible="is_district_head == False"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Child Units">
                            <field name="child_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_organogram_node" model="ir.actions.act_window">
        <field name="name">Organogram Structure</field>
        <field name="res_model">hr.organogram.node</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Define a new Organogram Position or Unit.
          </p><p>
            This is where you can build and edit the company's organizational hierarchy that appears on the Structural Chart.
          </p>
        </field>
    </record>

</odoo>