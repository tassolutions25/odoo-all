<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="view_department_form_extended_branch" model="ir.ui.view">
        <field name="name">hr.department.form.extended.branch</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="cost_center_id"/>
            </xpath>
            <xpath expr="//field[@name='manager_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
    <record id="view_department_form_extended_division" model="ir.ui.view">
        <field name="name">hr.department.form.extended.division</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_divisions"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-sitemap">
                    <field name="division_count" widget="statinfo" string="Divisions"/>
                </button>
            </div>
            
            <xpath expr="//sheet" position="inside">
                <notebook>
                    <page string="Divisions" name="divisions">
                        <field name="division_ids" nolabel="1">
                            <list>
                                <field name="sequence"/>
                                <field name="name"/>
                                <field name="manager_id"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>