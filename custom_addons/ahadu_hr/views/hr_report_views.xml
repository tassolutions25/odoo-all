<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_headcount_pivot" model="ir.ui.view">
        <field name="name">hr.employee.headcount.pivot</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <pivot string="Headcount Analysis" sample="1">
                <field name="department_id" type="row"/>
                <field name="grade_id" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_employee_headcount_graph" model="ir.ui.view">
        <field name="name">hr.employee.headcount.graph</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <graph string="Headcount by Department" sample="1">
                <field name="department_id"/>
            </graph>
        </field>
    </record>

    <record id="view_employee_headcount_search" model="ir.ui.view">
        <field name="name">hr.employee.headcount.search</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <search string="Headcount Analysis">
                <field name="department_id"/>
                <field name="grade_id"/>
                <field name="job_id"/>
                <field name="branch_id"/>
                <filter string="Active" name="active_employees" domain="[('active', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Department" name="group_by_department" context="{'group_by':'department_id'}"/>
                    <filter string="Grade" name="group_by_grade" context="{'group_by':'grade_id'}"/>
                    <filter string="Branch" name="group_by_branch" context="{'group_by':'branch_id'}"/>
                    <filter string="Job Position" name="group_by_job" context="{'group_by':'job_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_employee_headcount_report" model="ir.actions.act_window">
        <field name="name">Headcount Analysis</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">pivot,graph,list,form</field>
        <field name="search_view_id" ref="view_employee_headcount_search"/>
        <field name="context">{'search_default_active_employees': 1}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Headcount Analysis
          </p><p>
            This report provides a pivot table of your employee headcount,
            broken down by department and grade. Use the search panel to group by other criteria.
          </p>
        </field>
    </record>
</odoo>