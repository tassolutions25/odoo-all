<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_city_tree" model="ir.ui.view">
            <field name="name">hr.city.tree</field>
            <field name="model">hr.city</field>
            <field name="arch" type="xml">
                <list string="Cities">
                    <field name="name"/>
                    <field name="region_id"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </list>
            </field>
        </record>

        <record id="view_hr_city_form" model="ir.ui.view">
            <field name="name">hr.city.form</field>
            <field name="model">hr.city</field>
            <field name="arch" type="xml">
                <form string="City">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="region_id" options="{'no_create': True}"/>
                            </group>
                            <group>
                                <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hr_city_filter" model="ir.ui.view">
            <field name="name">hr.city.search</field>
            <field name="model">hr.city</field>
            <field name="arch" type="xml">
                <search string="Search Cities">
                    <field name="name"/>
                    <field name="region_id"/>
                    <group expand="0" string="Group By">
                        <filter string="Region" name="group_by_region" domain="[]" context="{'group_by': 'region_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_hr_city" model="ir.actions.act_window">
            <field name="name">Cities</field>
            <field name="res_model">hr.city</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Create a new City
              </p>
            </field>
        </record>
    </data>
</odoo>
