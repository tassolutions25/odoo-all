<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_cost_center_tree" model="ir.ui.view">
        <field name="name">hr.cost.center.tree</field>
        <field name="model">hr.cost.center</field>
        <field name="arch" type="xml">
            <list string="Cost Centers">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_hr_cost_center_form" model="ir.ui.view">
        <field name="name">hr.cost.center.form</field>
        <field name="model">hr.cost.center</field>
        <field name="arch" type="xml">
            <form string="Cost Center">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_cost_center" model="ir.actions.act_window">
        <field name="name">Cost Centers</field>
        <field name="res_model">hr.cost.center</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Cost Center.
            </p><p>
                Cost Centers are used to track costs for specific parts of your business, like departments or projects.
            </p>
        </field>
    </record>



</odoo>