                        <filter string="New Branch" name="group_by_new_branch" context="{'group_by': 'new_branch_id'}"/>
                        <filter string="Department" name="group_by_department" context="{'group_by': 'new_department_id'}"/>
                        <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                        <filter string="Transfer Date" name="group_by_date" context="{'group_by': 'transfer_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

