<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Activity Analysis Views -->

        <!-- Promotion Analysis Views -->
        <record id="hr_employee_promotion_view_graph" model="ir.ui.view">
            <field name="name">hr.employee.promotion.graph</field>
            <field name="model">hr.employee.promotion</field>
            <field name="arch" type="xml">
                <graph string="Promotion Analysis" sample="1">
                    <field name="new_grade_id"/>
                    <field name="state" type="row"/>
                </graph>
            </field>
        </record>

        <record id="hr_employee_promotion_view_pivot" model="ir.ui.view">
            <field name="name">hr.employee.promotion.pivot</field>
            <field name="model">hr.employee.promotion</field>
            <field name="arch" type="xml">
                <pivot string="Promotion Analysis" sample="1">
                    <field name="new_grade_id" type="row"/>
                    <field name="promotion_date" interval="month" type="col"/>
                </pivot>
            </field>
        </record>

        <record id="hr_employee_promotion_view_search_reports" model="ir.ui.view">
            <field name="name">hr.employee.promotion.search.reports</field>
            <field name="model">hr.employee.promotion</field>
            <field name="arch" type="xml">
                <search string="Promotion Analysis">
                    <field name="employee_id"/>
                    <field name="new_grade_id"/>
                    <field name="new_job_id"/>
                    <field name="new_department_id"/>
                    <separator/>
                    <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                    <filter string="This Year" name="this_year" domain="[('promotion_date', '&gt;=', datetime.datetime.now().replace(month=1, day=1))]"/>
                    <separator/>
                    <group expand="1" string="Group By">
                        <filter string="Grade" name="group_by_grade" context="{'group_by': 'new_grade_id'}"/>
                        <filter string="Department" name="group_by_department" context="{'group_by': 'new_department_id'}"/>
                        <filter string="Job Position" name="group_by_job" context="{'group_by': 'new_job_id'}"/>
                        <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                        <filter string="Promotion Date" name="group_by_date" context="{'group_by': 'promotion_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

