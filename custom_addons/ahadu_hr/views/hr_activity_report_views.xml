        <!-- Window Actions for Activity Reports -->
        <record id="action_promotion_analysis_report" model="ir.actions.act_window">
            <field name="name">Promotion Analysis</field>
            <field name="res_model">hr.employee.promotion</field>
            <field name="view_mode">graph,pivot,list,form</field>
            <field name="search_view_id" ref="hr_employee_promotion_view_search_reports"/>
            <field name="context">{'search_default_approved': 1, 'search_default_group_by_grade': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No promotions found.
                </p>
                <p>
                    This dashboard provides an overview of employee promotions.
                    Use the 'Group By' and 'Measures' menus to build your own reports.
                </p>
            </field>
        </record>

        <record id="action_transfer_analysis_report" model="ir.actions.act_window">
            <field name="name">Transfer Analysis</field>
            <field name="res_model">hr.employee.transfer</field>
            <field name="view_mode">graph,pivot,list,form</field>
            <field name="search_view_id" ref="hr_employee_transfer_view_search_reports"/>
            <field name="context">{'search_default_approved': 1, 'search_default_group_by_new_branch': 1}</field>
            <field name="help" type="html">
