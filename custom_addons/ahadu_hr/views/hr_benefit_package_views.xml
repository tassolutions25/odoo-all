<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Benefit Type Views -->
    <record id="view_hr_benefit_type_tree" model="ir.ui.view">
        <field name="name">hr.benefit.type.tree</field>
        <field name="model">hr.benefit.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="value_type"/>
            </list>
        </field>
    </record>

    <record id="view_hr_benefit_type_form" model="ir.ui.view">
        <field name="name">hr.benefit.type.form</field>
        <field name="model">hr.benefit.type</field>
        <field name="arch" type="xml">
            <form string="Benefit Type">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g., Housing Allowance"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" help="Unique code, e.g., 'HOUSING'"/>
                            <field name="value_type"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Benefit Package Views -->
    <record id="view_hr_benefit_package_tree" model="ir.ui.view">
        <field name="name">hr.benefit.package.tree</field>
        <field name="model">hr.benefit.package</field>
        <field name="arch" type="xml">
            <list string="Benefit Packages">
                <field name="name"/>
                <field name="job_ids" widget="many2many_tags"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_hr_benefit_package_form" model="ir.ui.view">
        <field name="name">hr.benefit.package.form</field>
        <field name="model">hr.benefit.package</field>
        <field name="arch" type="xml">
            <form string="Benefit Package">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g., Executive Staff Package"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="job_ids" widget="many2many_tags" placeholder="Select applicable job positions..."/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Benefit Rules" name="benefit_rules">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="benefit_type_id" options="{'no_create': True}"/>
                                    <field name="value_type" invisible="1"/>
                                    <field name="value_fixed" invisible="value_type != 'fixed'" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="value_percentage" invisible="value_type != 'percentage'"/>
                                    <field name="value_in_kind" invisible="value_type != 'in_kind'"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_benefit_type" model="ir.actions.act_window">
        <field name="name">Benefit Types</field>
        <field name="res_model">hr.benefit.type</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_hr_benefit_package" model="ir.actions.act_window">
        <field name="name">Benefit Packages</field>
        <field name="res_model">hr.benefit.package</field>
        <field name="view_mode">list,form</field>
    </record>

    </odoo>