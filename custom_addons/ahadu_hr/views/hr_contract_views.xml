<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_contract_view_form_inherit_ahadu_grade" model="ir.ui.view">
        <field name="name">hr.contract.view.form.inherit.ahadu.grade</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
        <xpath expr="//field[@name='job_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='department_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group[@name='salary_info']" position="inside">
                <field name="employee_id" position="attributes">
                    <attribute name="context">{'show_grade': True}</attribute>
                </field>
            </xpath>
            <xpath expr="//group[@name='salary']" position="inside">
            </xpath>
        </field>
    </record>
</odoo> 