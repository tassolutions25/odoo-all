<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Benefit Type Views -->
    <record id="view_hr_benefit_tree" model="ir.ui.view">
        <field name="name">hr.benefit.tree</field>
        <field name="model">hr.benefit</field>
        <field name="arch" type="xml">
            <list string="Benefit Types">
                <field name="name"/>
                <field name="code"/>
                <field name="benefit_type"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_hr_benefit_form" model="ir.ui.view">
        <field name="name">hr.benefit.form</field>
        <field name="model">hr.benefit</field>
        <field name="arch" type="xml">
            <form string="Benefit Type">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g., Medical Insurance"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="benefit_type"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Benefit Plan Views -->
    <record id="view_hr_benefit_plan_tree" model="ir.ui.view">
        <field name="name">hr.benefit.plan.tree</field>
        <field name="model">hr.benefit.plan</field>
        <field name="arch" type="xml">
            <list string="Benefit Plans">
                <field name="name"/>
                <field name="grade_ids" widget="many2many_tags"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_hr_benefit_plan_form" model="ir.ui.view">
        <field name="name">hr.benefit.plan.form</field>
        <field name="model">hr.benefit.plan</field>
        <field name="arch" type="xml">
            <form string="Benefit Plan">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g., Management Staff Plan"/></h1>
                    </div>
                    <group>
                        <field name="grade_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Benefit Rules">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="benefit_id"/>
                                    <field name="limit_amount" widget="monetary"/>
                                    <field name="frequency"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Benefit Claim Views -->
    <record id="view_hr_benefit_claim_tree" model="ir.ui.view">
        <field name="name">hr.benefit.claim.tree</field>
        <field name="model">hr.benefit.claim</field>
        <field name="arch" type="xml">
            <list string="Benefit Claims">
                <field name="employee_id"/>
                <field name="benefit_id"/>
                <field name="claim_date"/>
                <field name="claim_amount" sum="Total Claimed" widget="monetary"/>
                <field name="state" widget="badge" decoration-success="state == 'paid'" decoration-info="state == 'approved'" decoration-warning="state == 'submitted'"/>
            </list>
        </field>
    </record>
    
    <record id="view_hr_benefit_claim_form" model="ir.ui.view">
        <field name="name">hr.benefit.claim.form</field>
        <field name="model">hr.benefit.claim</field>
        <field name="arch" type="xml">
            <form string="Benefit Claim">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-success" invisible="state != 'submitted'" groups="hr.group_hr_manager"/>
                    <button name="action_set_to_paid" string="Set to Paid" type="object" class="btn-primary" invisible="state != 'approved'" groups="hr.group_hr_manager"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="state not in ['submitted', 'approved']" groups="hr.group_hr_manager"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" class="oe_link" invisible="state not in ['rejected', 'submitted']" groups="hr.group_hr_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g., Hospital visit receipt"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="benefit_plan_id" readonly="1"/>
                            <field name="benefit_line_id" options="{'no_create': True}"/>
                            <field name="benefit_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="claim_date"/>
                            <field name="claim_amount" widget="monetary"/>
                            <field name="eyeglass_purchase_date" invisible="benefit_id != %(ahadu_hr.hr_benefit_eyeglass)d"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_hr_benefit" model="ir.actions.act_window">
        <field name="name">Benefit Types</field>
        <field name="res_model">hr.benefit</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_hr_benefit_plan" model="ir.actions.act_window">
        <field name="name">Benefit Plans</field>
        <field name="res_model">hr.benefit.plan</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_hr_benefit_claim" model="ir.actions.act_window">
        <field name="name">Benefit Claims</field>
        <field name="res_model">hr.benefit.claim</field>
        <field name="view_mode">list,form</field>
    </record>

