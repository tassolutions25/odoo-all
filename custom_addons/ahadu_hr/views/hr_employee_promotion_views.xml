<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <record id="view_employee_promotion_form" model="ir.ui.view">
        <field name="name">hr.employee.promotion.form</field>
        <field name="model">hr.employee.promotion</field>
        <field name="arch" type="xml">
            <form string="Employee Promotion">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve_step" string="Approve" type="object" class="btn-success" invisible="can_approve == False"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="can_approve == False"/>
                    <button name="action_draft" string="Reset to Draft" type="object" class="oe_link" invisible="state not in ('submitted', 'rejected')" groups="hr.group_hr_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Employee Promotion</h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="promotion_date"/>
                        </group>
                        <group>
                            <field name="next_approver_ids" widget="many2many_tags" readonly="1" invisible="state != 'submitted'"/>
                            <field name="can_approve" invisible="1"/>
                        </group>
                    </group>

                    <div class="row">
                        <div class="col-md-6">
                            <group string="Current Information">
                                <field name="current_job_id"/>
                                <field name="current_grade_id"/>
                                <field name="current_department_id"/>
                                <field name="current_division_id"/>
                                <field name="current_branch_id"/>
                                <field name="current_cost_center_id"/>
                                <field name="current_salary" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </div>
                        <div class="col-md-6">
                            <group string="New Information">
                                <field name="new_job_id"/>
                                <field name="new_grade_id"/>
                                <field name="new_department_id"/>
                                <field name="new_division_id"/>
                                <field name="new_branch_id"/>
                                    <field name="new_cost_center_id"/>
                                <field name="new_salary" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </div>
                    </div>

                    <group>
                        <field name="reason" placeholder="Enter reason for promotion..."/>
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="approval_line_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="approver_id"/>
                                    <field name="status"/>
                                    <field name="approval_date"/>
                                    <field name="comments"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_promotion_tree" model="ir.ui.view">
        <field name="name">hr.employee.promotion.tree</field>
        <field name="model">hr.employee.promotion</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="promotion_date"/>
                <field name="current_job_id"/>
                <field name="new_job_id"/>
                <field name="current_grade_id"/>
                <field name="new_grade_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_employee_promotion_search" model="ir.ui.view">
        <field name="name">hr.employee.promotion.search</field>
        <field name="model">hr.employee.promotion</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="current_job_id"/>
                <field name="new_job_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    </data>
</odoo>