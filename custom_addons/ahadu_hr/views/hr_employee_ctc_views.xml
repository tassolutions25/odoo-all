<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_employee_ctc_form" model="ir.ui.view">
            <field name="name">hr.employee.ctc.form</field>
            <field name="model">hr.employee.ctc</field>
            <field name="arch" type="xml">
                <form string="CTC Adjustment">
                    <header>
                        <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_approve_step" string="Approve" type="object" class="btn-success" invisible="can_approve == False"/>
                        <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="can_approve == False"/>
                        <button name="action_draft" string="Reset to Draft" type="object" class="oe_link" invisible="state not in ('submitted', 'rejected')" groups="hr.group_hr_user"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="employee_id" readonly="state != 'draft'"/>
                                <field name="date" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="next_approver_ids" widget="many2many_tags" readonly="1" invisible="state != 'submitted'"/>
                                <field name="can_approve" invisible="1"/>
                            </group>
                        </group>

                        <div class="row">
                            <div class="col-md-6">
                                <group string="Current Compensation">
                                    <field name="current_wage" widget="monetary"/>
                                    <field name="current_grade_id"/>
                                    <field name="current_job_id"/>
                                    <field name="current_department_id"/>
                                    <field name="currency_id" invisible="1"/>
                                </group>
                            </div>
                            <div class="col-md-6">
                                <group string="New Compensation">
                                    <field name="new_wage" widget="monetary" readonly="state != 'draft'"/>
                                    <field name="new_grade_id" readonly="state != 'draft'" placeholder="Leave empty if no change"/>
                                    <field name="new_job_id" readonly="state != 'draft'" placeholder="Leave empty if no change"/>
                                    <field name="new_department_id" readonly="state != 'draft'" placeholder="Leave empty if no change"/>
                                </group>
                            </div>
                        </div>

                        <group>
                            <field name="reason" placeholder="Reason for salary adjustment..."/>
                        </group>
                        <notebook>
                            <page string="Approval History">
                                <field name="approval_line_ids" readonly="1">
                                    <list>
                                        <field name="sequence" widget="handle"/>
                                        <field name="approver_id"/>
                                        <field name="status"/>
                                        <field name="approval_date"/>
                                        <field name="comments"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_employee_ctc_tree" model="ir.ui.view">
            <field name="name">hr.employee.ctc.tree</field>
            <field name="model">hr.employee.ctc</field>
            <field name="arch" type="xml">
                <list decoration-info="state == 'draft'" decoration-success="state == 'approved'">
                    <field name="employee_id"/>
                    <field name="date"/>
                    <field name="current_wage" widget="monetary"/>
                    <field name="new_wage" widget="monetary"/>
                    <field name="state" widget="badge"/>
                    <field name="currency_id" invisible="1"/>
                </list>
            </field>
        </record>

        <record id="action_employee_ctc" model="ir.actions.act_window">
            <field name="name">CTC Adjustments</field>
            <field name="res_model">hr.employee.ctc</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Create a new CTC Adjustment
              </p>
            </field>
        </record>

        <menuitem id="menu_hr_employee_ctc"
                  name="CTC Adjustments"
                  parent="hr.menu_hr_employee_payroll"
                  action="action_employee_ctc"
                  sequence="20"/>
    </data>
</odoo>