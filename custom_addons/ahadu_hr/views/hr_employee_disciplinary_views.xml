<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
    <record id="view_employee_disciplinary_form" model="ir.ui.view">
        <field name="name">hr.employee.disciplinary.form</field>
        <field name="model">hr.employee.disciplinary</field>
        <field name="arch" type="xml">
             <form string="Employee Disciplinary Action">
                 <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve_step" string="Approve" type="object" class="btn-success" invisible="can_approve == False"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="can_approve == False"/>
                    <button name="action_draft" string="Reset to Draft" type="object" class="oe_link" invisible="state not in ('submitted', 'rejected')" groups="hr.group_hr_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Disciplinary Action</h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="action_date"/>
                            <field name="action_type"/>
                        </group>
                        <group>
                            <field name="duration" invisible="action_type != 'suspension'" required="action_type == 'suspension'"/>
                            <field name="next_approver_ids" widget="many2many_tags" readonly="1" invisible="state != 'submitted'"/>
                            <field name="can_approve" invisible="1"/>
                        </group>
                    </group>
                    
                    <group>
                        <field name="violation" placeholder="Describe the violation..."/>
                    </group>
                    
                    <group>
                        <field name="action_taken" placeholder="Describe the action taken..."/>
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="approval_line_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="approver_id"/>
                                    <field name="status"/>
                                    <field name="approval_date"/>
                                    <field name="comments"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_disciplinary_tree" model="ir.ui.view">
        <field name="name">hr.employee.disciplinary.tree</field>
        <field name="model">hr.employee.disciplinary</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="action_date"/>
                <field name="action_type"/>
                <field name="duration"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_employee_disciplinary_search" model="ir.ui.view">
        <field name="name">hr.employee.disciplinary.search</field>
        <field name="model">hr.employee.disciplinary</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="action_type"/>
                <filter string="Warning" name="warning" domain="[('action_type', '=', 'warning')]"/>
                <filter string="Suspension" name="suspension" domain="[('action_type', '=', 'suspension')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Action Type" name="group_action_type" context="{'group_by': 'action_type'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    </data>
</odoo>