                <field name="experience_place"/>
                <field name="attachment" widget="binary" filename="attachment_filename"/>
                <field name="attachment_filename" invisible="1"/>
            </xpath>
        </field>
    </record> -->
    
    <record id="hr_resume_line_form_view_inherit_ahadu_attachment" model="ir.ui.view">
        <field name="name">hr.resume.line.form.inherit.ahadu.attachment</field>
        <field name="model">hr.resume.line</field>
        <field name="inherit_id" ref="hr_skills.resume_line_view_form"/>
        <field name="arch" type="xml">
        <xpath expr="//field[@name='name']" position="after">
                 <field name="experience_place" placeholder="Experience Place"/>
             </xpath>
             <xpath expr="//group" position="inside">
                <group string="Attachment">
                    <field name="attachment" widget="binary" filename="attachment_filename"/>
                    <field name="attachment_filename" invisible="1"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>