<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_view_form_inherit_resume_ahadu" model="ir.ui.view">
        <field name="name">hr.employee.form.resume.inherit.ahadu</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr_skills.hr_employee_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='skills_resume']" position="attributes">
                <attribute name="string">Resume and Experience</attribute>
            </xpath>
            <xpath expr="//field[@name='resume_line_ids']/preceding-sibling::separator[1]" position="attributes">
                <attribute name="string">Experience</attribute>
            </xpath>
            <!-- Add the separate CV/Resume upload section after the experience lines -->
            <xpath expr="//field[@name='resume_line_ids']" position="after">
                <separator string="CV / Resume File"/>
                <group>
                    <field name="resume_attachment" widget="binary" filename="resume_attachment_filename"/>
                    <field name="resume_attachment_filename" invisible="1"/>
                </group>
            </xpath>
        </field>
    </record>

