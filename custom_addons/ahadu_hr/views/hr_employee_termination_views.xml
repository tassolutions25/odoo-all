<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_termination_form" model="ir.ui.view">
        <field name="name">hr.employee.termination.form</field>
        <field name="model">hr.employee.termination</field>
        <field name="arch" type="xml">
            <form string="Employee Termination">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve_step" string="Approve" type="object" class="btn-success" invisible="can_approve == False"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="can_approve == False"/>
                    <button name="action_draft" string="Reset to Draft" type="object" class="oe_link" invisible="state not in ('submitted', 'rejected')" groups="hr.group_hr_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Employee Termination</h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="termination_date"/>
                            <!-- <field name="termination_type"/> -->
                        </group>
                        <group>
                            <field name="next_approver_ids" widget="many2many_tags" readonly="1" invisible="state != 'submitted'"/>
                            <field name="can_approve" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" placeholder="Enter reason for termination..."/>
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="approval_line_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="approver_id"/>
                                    <field name="status"/>
                                    <field name="approval_date"/>
                                    <field name="comments"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_termination_tree" model="ir.ui.view">
        <field name="name">hr.employee.termination.tree</field>
        <field name="model">hr.employee.termination</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="termination_date"/>
                <field name="reason" optional="show"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_employee_termination_search" model="ir.ui.view">
        <field name="name">hr.employee.termination.search</field>
        <field name="model">hr.employee.termination</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <record id="action_employee_termination" model="ir.actions.act_window">
        <field name="name">Employee Terminations</field>
        <field name="res_model">hr.employee.termination</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>