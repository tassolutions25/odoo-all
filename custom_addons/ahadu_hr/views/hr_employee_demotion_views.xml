<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <record id="view_employee_demotion_form" model="ir.ui.view">
        <field name="name">hr.employee.demotion.form</field>
        <field name="model">hr.employee.demotion</field>
        <field name="arch" type="xml">
             <form string="Employee Demotion">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve_step" string="Approve" type="object" class="btn-success" invisible="can_approve == False"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="can_approve == False"/>
                    <button name="action_draft" string="Reset to Draft" type="object" class="oe_link" invisible="state not in ('submitted', 'rejected')" groups="hr.group_hr_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Employee Demotion</h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_number_search" placeholder="e.g. AHB1234"/>
                            <field name="employee_id"/>
                            <field name="demotion_date"/>
                        </group>
                        <group>
                            <field name="next_approver_ids" widget="many2many_tags" readonly="1" invisible="state != 'submitted'"/>
                            <field name="can_approve" invisible="1"/>
                        </group>
                    </group>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <group string="Current Information">
                                <field name="current_job_id"/>
                                <field name="current_grade_id"/>
                                <field name="current_department_id"/>
                                <field name="current_division_id"/>
                                <field name="current_branch_id"/>
                                <field name="current_cost_center_id"/>
                                <field name="current_parent_id"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </div>
                        <div class="col-md-6">
                            <group string="New Information">
                                <field name="new_job_id"/>
                                <field name="new_grade_id"/>
                                <field name="new_department_id"/>
                                <field name="new_division_id"/>
                                <field name="new_branch_id"/>
                                <field name="new_cost_center_id"/>
                                <field name="new_parent_id" placeholder="Select new manager if changing"/>
                            </group>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <group string="Current Allowances">
                                <field name="current_housing_allowance" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="current_mobile_allowance" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="current_transport_allowance_liters"/>
                                <field name="current_representation_allowance"/>
                                <field name="current_hardship_allowance_level_id"/>
                            </group>
                        </div>
                        <div class="col-md-6">
                            <group string="New Allowances">
                                <field name="new_housing_allowance" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="state != 'draft'"/>
                                <field name="new_mobile_allowance" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="state != 'draft'"/>
                                <field name="new_transport_allowance_liters" readonly="state != 'draft'"/>
                                <field name="new_representation_allowance" readonly="state != 'draft'"/>
                                <field name="new_hardship_allowance_level_id" readonly="state != 'draft'"/>
                            </group>
                        </div>
                    </div>
                    
                    <group>
                        <field name="reason" placeholder="Enter reason for demotion..." required="1"/>
                        <field name="approve_uid"/>
                    </group>
                    <group string="Attachments">
                        <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="approval_line_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="approver_id"/>
                                    <field name="status"/>
                                    <field name="approval_date"/>
                                    <field name="comments"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="view_employee_demotion_tree" model="ir.ui.view">
        <field name="name">hr.employee.demotion.tree</field>
        <field name="model">hr.employee.demotion</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="demotion_date"/>
                <field name="current_job_id"/>
                <field name="new_job_id"/>
                <field name="current_grade_id"/>
                <field name="new_grade_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    </data>
</odoo>