<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Security Groups -->
        <record id="group_ahadu_hr_user" model="res.groups">
            <field name="name">Ahadu HR User</field>
            <field name="category_id" ref="hr.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
        </record>

        <record id="group_ahadu_hr_manager" model="res.groups">
            <field name="name">Ahadu HR Manager</field>
            <field name="category_id" ref="hr.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('group_ahadu_hr_user')), (4, ref('hr.group_hr_manager'))]"/>
        </record>

        <!-- Record Rules -->
        <record id="rule_employee_activity_user" model="ir.rule">
            <field name="name">Employee Activity User Rule</field>
            <field name="model_id" ref="model_hr_employee_activity"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ahadu_hr_user'))]"/>
        </record>

        <record id="rule_employee_activity_manager" model="ir.rule">
            <field name="name">Employee Activity Manager Rule</field>
            <field name="model_id" ref="model_hr_employee_activity"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ahadu_hr_manager'))]"/>
        </record>

        <!-- Similar rules for other models -->
        <record id="rule_employee_promotion_user" model="ir.rule">
            <field name="name">Employee Promotion User Rule</field>
            <field name="model_id" ref="model_hr_employee_promotion"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ahadu_hr_user'))]"/>
        </record>

        <record id="rule_employee_transfer_user" model="ir.rule">
            <field name="name">Employee Transfer User Rule</field>
            <field name="model_id" ref="model_hr_employee_transfer"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ahadu_hr_user'))]"/>
        </record>

        <record id="rule_employee_lateral_user" model="ir.rule">
            <field name="name">Employee Lateral User Rule</field>
            <field name="model_id" ref="model_hr_employee_lateral"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ahadu_hr_user'))]"/>
        </record>
    </data>
</odoo>