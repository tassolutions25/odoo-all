<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_archive_resigned_employees" model="ir.cron">
            <field name="name">HR: Archive Resigned Employees (Auto-Execution)</field>
            <field name="model_id" ref="ahadu_hr.model_hr_employee_resignation"/>
            <field name="state">code</field>
            <field name="code">model._cron_archive_resigned_employees()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.now()).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>

        <record id="ir_cron_check_suspension_end" model="ir.cron">
            <field name="name">HR: Check Suspension End Dates</field>
            <field name="model_id" ref="model_hr_employee_suspension"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_suspension_end()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>