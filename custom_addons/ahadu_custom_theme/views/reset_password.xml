<odoo>
    <data>
        <!-- Inherit the reset password template -->
      <template id="inherit_reset_password" inherit_id="auth_signup.reset_password">
      <xpath expr="//form[contains(@class, 'oe_reset_password_form')]" position="before">
                <h5 class="text-center my-2">AHADU-ERP</h5>
            </xpath>
    <xpath expr="//label[@for='login']" position="replace">
        <label for="login" class="col-form-label">AHADU ID</label>
    </xpath>
         <xpath expr="//div[contains(@class, 'field-login')]/label[@for='login']" position="replace">
                <label for="login" class="col-form-label">Your ID</label>
            </xpath>
</template>

        <template id="inherit_reset_password_fields" inherit_id="auth_signup.fields">
             
                <!-- Insert the "AHADU-ERP" title before the form or before 'field-login' -->
   

       
            <!-- Password field with toggle functionality -->
            <xpath expr="//div[contains(@class, 'mb-3 field-password')]" position="replace">
                <div class="mb-3 field-password pt-2" style="min-width: 250px; max-width: 300px;">
                    <label for="password">Password</label>
                    <div class="input-group">
                        <input type="password" name="password" id="password" class="form-control form-control-sm"
                            required="required" t-att-autofocus="'autofocus' if only_passwords else None"/>
                        <span class="fa fa-eye-slash input-group-text" id="rt_toggle_password" ></span> 
                    </div>
                </div>
            </xpath>
            <!-- Password field with toggle functionality -->
            <xpath expr="//div[contains(@class, 'field-confirm_password')]" position="replace">
                <div class="mb-3 field-confirm_password">
                    <label for="confirm_password">Confirm Password</label>
                    <div class="input-group">
                        <input type="password" name="confirm_password" id="confirm_password" class="form-control form-control-sm" required="required"/>
                        <span class="fa fa-eye-slash input-group-text" id="rt_toggle_confirm_password"></span>
                    </div>
                </div>
            </xpath>

        </template>
    </data>
</odoo>
