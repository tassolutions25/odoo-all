<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_document_request_tree" model="ir.ui.view">
        <field name="name">hr.document.request.tree</field>
        <field name="model">hr.document.request</field>
        <field name="arch" type="xml">
            <list string="Document Requests" decoration-info="state=='submitted'" decoration-success="state=='approved'" decoration-danger="state=='rejected'">
                <field name="employee_id"/>
                <field name="document_type"/>
                <field name="create_date" string="Request Date"/>
                <field name="next_approver_ids" widget="many2many_tags"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_hr_document_request_form" model="ir.ui.view">
        <field name="name">hr.document.request.form</field>
        <field name="model">hr.document.request</field>
        <field name="arch" type="xml">
            <form string="Document Request">
                <header>
                    <button name="action_approve_step" string="Approve" type="object" class="btn-success" invisible="can_approve == False"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="can_approve == False"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="document_type"/>
                            <field name="document_file" widget="binary" filename="document_filename"/>
                            <field name="document_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="create_date" string="Request Date"/>
                            <field name="next_approver_ids" widget="many2many_tags" readonly="1" invisible="state != 'submitted'"/>
                            <field name="can_approve" invisible="1"/>
                        </group>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="approval_line_ids" readonly="1">
                            <list>
                                <field name="sequence" widget="handle"/>
                                <field name="approver_id"/>
                                <field name="status" widget="badge" decoration-success="status == 'approved'" decoration-warning="status == 'pending'" decoration-danger="status == 'rejected'"/>
                                <field name="approval_date"/>
                                <field name="comments"/>
                            </list>
                        </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_document_request" model="ir.actions.act_window">
        <field name="name">Document Requests</field>
        <field name="res_model">hr.document.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- 
    <menuitem id="menu_hr_document_requests"
        name="Document Requests"
        parent="ahadu_hr.menu_all_activities_list"
        action="action_hr_document_request"
        sequence="20"/>
    -->
</odoo>