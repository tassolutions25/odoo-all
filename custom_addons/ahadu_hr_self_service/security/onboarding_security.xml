<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hr_onboarding_self_rule" model="ir.rule">
            <field name="name">Onboarding: Own Documents Only</field>
            <field name="model_id" ref="model_hr_employee_onboarding"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="hr_onboarding_manager_rule" model="ir.rule">
            <field name="name">Onboarding: HR Manager Full Access</field>
            <field name="model_id" ref="model_hr_employee_onboarding"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
        </record>
    </data>
</odoo>