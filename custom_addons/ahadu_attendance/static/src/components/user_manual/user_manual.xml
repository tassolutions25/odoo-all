<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ahadu_attendance.UserManualViewer" owl="1">
        <div class="o_action_manager o_ahadu_user_manual_viewer h-100 d-flex flex-column bg-view">
            <div class="o_control_panel d-flex flex-column gap-3 gap-lg-1 px-3 pt-2 pb-3" style="background-color: white; border-bottom: 1px solid #dee2e6;">
                <div class="o_control_panel_main d-flex flex-wrap flex-lg-nowrap justify-content-between align-items-center gap-3 gap-lg-1">
                    <div class="o_control_panel_breadcrumbs d-flex align-items-center gap-1 order-0 h2 mb-0">
                        <span class="min-w-0 text-truncate text-break">User Manual</span>
                    </div>
                    
                    <div class="o_control_panel_actions d-flex align-items-center gap-1 gap-lg-2 order-2 order-lg-1">
                        <button type="button" class="btn btn-primary o_form_button_save" t-on-click="onDownload" style="background-color: #800020; border-color: #800020;">
                            <i class="fa fa-download me-1"></i> Download PDF
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="o_content flex-grow-1 overflow-auto position-relative">
                <iframe t-att-src="pdfUrl" class="w-100 h-100" style="border: none;"></iframe>
            </div>
        </div>
    </t>
</templates>
