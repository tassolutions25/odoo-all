<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ab_hr_shift_type_tree" model="ir.ui.view">
        <field name="name">ab.hr.shift.type.tree</field>
        <field name="model">ab.hr.shift.type</field>
        <field name="arch" type="xml">
            <list string="Shift Types">
                <field name="name"/>
                <field name="company_id"/>
                <field name="shift_category"/>
            </list>
        </field>
    </record>

    <record id="view_ab_hr_shift_type_form" model="ir.ui.view">
        <field name="name">ab.hr.shift.type.form</field>
        <field name="model">ab.hr.shift.type</field>
        <field name="arch" type="xml">
            <form string="Shift Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="shift_category"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Working Hours" name="working_hours">
                            <field name="attendance_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="dayofweek"/>
                                    <field name="hour_from" widget="float_time"/>
                                    <field name="hour_to" widget="float_time"/>
                                    <field name="day_period"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ab_hr_shift_type" model="ir.actions.act_window">
        <field name="name">Shift Types</field>
        <field name="res_model">ab.hr.shift.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>