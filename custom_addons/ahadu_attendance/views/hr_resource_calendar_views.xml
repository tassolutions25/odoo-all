<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
        This file modifies Odoo's existing "Working Times" (resource.calendar)
        to act as our "Shift Types".
    -->

    <!-- Inherit the form view of Working Times to add our category field -->
    <record id="resource_calendar_view_form_inherit_shift" model="ir.ui.view">
        <field name="name">resource.calendar.form.inherit.shift</field>
        <field name="model">resource.calendar</field>
        <field name="inherit_id" ref="resource.resource_calendar_form"/>
        <field name="arch" type="xml">
            <field name="company_id" position="after">
                <field name="shift_category"/>
            </field>
        </field>
    </record>

    <!-- Inherit the tree view to make our category field visible -->
    <record id="resource_calendar_view_tree_inherit_shift" model="ir.ui.view">
        <field name="name">resource.calendar.tree.inherit.shift</field>
        <field name="model">resource.calendar</field>
        <!-- 
            THIS IS THE FIX:
            The correct ID is 'view_resource_calendar_tree'.
        -->
        <field name="inherit_id" ref="resource.view_resource_calendar_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="shift_category" optional="show"/>
            </field>
        </field>
    </record>
</odoo>