<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Duty Request Tree View -->
    <record id="view_ab_hr_duty_request_tree" model="ir.ui.view">
        <field name="name">ab.hr.duty.request.tree</field>
        <field name="model">ab.hr.duty.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="duty_location"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'confirm'" decoration-success="state == 'approved'" decoration-danger="state == 'refused'"/>
            </list>
        </field>
    </record>

    <!-- Duty Request Form View -->
    <record id="view_ab_hr_duty_request_form" model="ir.ui.view">
        <field name="name">ab.hr.duty.request.form</field>
        <field name="model">ab.hr.duty.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Add your approval workflow buttons here, similar to hr.leave -->
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm,approved"/>
                </header>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="duty_location"/>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action for Duty Requests -->
    <record id="action_ab_hr_duty_request" model="ir.actions.act_window">
        <field name="name">On Duty Requests</field>
        <field name="res_model">ab.hr.duty.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item for Duty Requests -->
    <!-- <menuitem
        id="menu_hr_duty_request"
        name="On Duty Requests"
        parent="hr_attendance.menu_hr_attendance_root"
        action="action_ab_hr_duty_request"
        sequence="25"/> -->
</odoo>