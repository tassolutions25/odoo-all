<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_ab_hr_shift_schedule_tree" model="ir.ui.view">
        <field name="name">ab.hr.shift.schedule.tree</field>
        <field name="model">ab.hr.shift.schedule</field>
        <field name="arch" type="xml">
            <!-- FIX 1: Reverted to <list> as required by your Odoo build -->
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="shift_type_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_ab_hr_shift_schedule_form" model="ir.ui.view">
        <field name="name">ab.hr.shift.schedule.form</field>
        <field name="model">ab.hr.shift.schedule</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_shift_assign" string="Assign" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_shift_cancel" string="Cancel" type="object" invisible="state not in ('draft', 'assigned')"/>
                    <button name="action_shift_reset_draft" string="Reset to Draft" type="object" invisible="state == 'draft'"/>
                    
                    <button name="action_open_calendar_view" string="Calendar View" type="object" class="btn-secondary"/>
                    <button name="action_open_gantt_view" string="Gantt View" type="object" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,assigned,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="employee_id" readonly="state != 'draft'"/>
                        <field name="department_id" readonly="1"/>
                        <field name="shift_type_id" readonly="state != 'draft'"/>
                        <field name="date_start" readonly="state != 'draft'"/>
                        <field name="date_end" readonly="state != 'draft'"/>
                        <field name="color"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
     <!-- Calendar View -->
    <record id="view_ab_hr_shift_schedule_calendar" model="ir.ui.view">
        <field name="name">ab.hr.shift.schedule.calendar</field>
        <field name="model">ab.hr.shift.schedule</field>
        <field name="arch" type="xml">
            <calendar string="Shift Schedule" date_start="date_start" date_stop="date_end" color="employee_id">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="shift_type_id"/>
            </calendar>
        </field>
    </record>

    <!-- Main Action Window -->
    <record id="action_ab_hr_shift_schedule" model="ir.actions.act_window">
        <field name="name">Shift Schedule</field>
        <field name="res_model">ab.hr.shift.schedule</field>
        <field name="view_mode">calendar,list,form</field>
    </record>

    <!-- Server Action for the Mass Schedule Button -->
    <record id="action_mass_schedule_shifts_button" model="ir.actions.server">
        <field name="name">Mass Schedule</field>
        <field name="model_id" ref="model_ab_hr_shift_schedule"/>
        <field name="binding_model_id" ref="model_ab_hr_shift_schedule"/>
        <field name="state">code</field>
        <!-- FIX 2: Removed all indentation from the Python code block -->
        <field name="code">
action = env.ref('ahadu_attendance.action_launch_shift_mass_schedule_wizard').read()[0]
action['target'] = 'new'
action
</field>

    </record>
</odoo>