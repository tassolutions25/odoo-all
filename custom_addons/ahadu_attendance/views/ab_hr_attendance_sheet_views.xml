<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Attendance Sheet Search View -->
    <record id="view_ab_hr_attendance_sheet_search" model="ir.ui.view">
        <field name="name">ab.hr.attendance.sheet.search</field>
        <field name="model">ab.hr.attendance.sheet</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="manager_id"/>
                <filter string="My Sheets" name="my_sheets" domain="[('employee_id.user_id', '=', uid)]"/>
                <filter string="My Team's Sheets" name="my_team_sheets" domain="[('manager_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="groupby_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Manager" name="groupby_manager" context="{'group_by': 'manager_id'}"/>
                    <filter string="Status" name="groupby_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Attendance Sheet Tree View -->
    <record id="view_ab_hr_attendance_sheet_tree" model="ir.ui.view">
        <field name="name">ab.hr.attendance.sheet.tree</field>
        <field name="model">ab.hr.attendance.sheet</field>
        <field name="arch" type="xml">
            <!-- Corrected: The tag for list views is <tree> -->
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="manager_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="total_worked_hours" sum="Total Worked Hours"/>
                <field name="total_late_minutes" sum="Total Late Minutes"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'submitted'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- Attendance Sheet Form View -->
    <record id="view_ab_hr_attendance_sheet_form" model="ir.ui.view">
        <field name="name">ab.hr.attendance.sheet.form</field>
        <field name="model">ab.hr.attendance.sheet</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Corrected: Replaced all 'attrs' with 'invisible' -->
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" groups="hr.group_hr_manager" invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Reject" type="object" groups="hr.group_hr_manager" invisible="state not in ['submitted', 'approved']"/>
                    <button name="action_to_draft" string="Set to Draft" type="object" invisible="state not in ['rejected']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <!-- Corrected: 'attrs' for readonly becomes the 'readonly' attribute directly -->
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="manager_id"/>
                        </group>
                        <group>
                            <field name="date_from" readonly="state != 'draft'"/>
                            <field name="date_to" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Attendance Entries">
                             <button name="action_get_attendances" string="Fetch Attendances for Period" type="object" class="btn-link" invisible="state != 'draft'"/>
                            <field name="attendance_ids" readonly="1">
                                <list>
                                    <field name="check_in"/>
                                    <field name="check_out"/>
                                    <field name="worked_hours" widget="float_time"/>
                                    <field name="attendance_status" widget="badge" decoration-success="attendance_status == 'on_time'" decoration-warning="attendance_status in ('late_in', 'early_out')" decoration-danger="attendance_status == 'late_in_early_out'"/>
                                    <field name="late_minutes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action for Attendance Sheets -->
    <record id="action_ab_hr_attendance_sheet" model="ir.actions.act_window">
        <field name="name">Attendance Sheets</field>
        <field name="res_model">ab.hr.attendance.sheet</field>
        <!-- Corrected: 'list' is deprecated for view_mode, use 'tree' -->
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_team_sheets': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new attendance sheet for approval.
            </p>
        </field>
    </record>
</odoo>