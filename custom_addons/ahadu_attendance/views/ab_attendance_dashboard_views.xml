<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ab_attendance_dashboard_kanban" model="ir.ui.view">
        <field name="name">ab.attendance.dashboard.kanban</field>
        <!--
            THIS IS THE FIX:
            The dashboard view is for the existing 'hr.attendance' model.
            It's not for a new model named 'ab.hr.attendance'.
        -->
        <field name="model">hr.attendance</field>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <!-- This is a placeholder. The Owl component 'ahadu_attendance.dashboard' 
                 will be mounted by the client action and will replace this content. -->
            <kanban create="0" class="o_kanban_view">
                <templates>
                    <t t-name="kanban-box">
                        <div></div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>