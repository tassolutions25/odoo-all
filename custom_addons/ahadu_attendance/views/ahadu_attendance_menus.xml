<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ======================================================
         1. DEFINE ALL PARENT (ROOT) MENUS FIRST
         ====================================================== -->

    <!-- Management Root -->
    <menuitem
        id="menu_ahadu_management_root"
        name="Activities"
        parent="hr_attendance.menu_hr_attendance_root"
        sequence="5"/>

    <!-- My Requests Root -->
    <menuitem
        id="menu_ahadu_my_requests_root"
        name="My Requests"
        parent="hr_attendance.menu_hr_attendance_root"
        sequence="6"/>

    <!-- Custom Reporting Root -->
    <menuitem 
        id="menu_ahadu_custom_reporting_root"
        name="Custom Reports"
        parent="hr_attendance.menu_hr_attendance_root"
        sequence="95"
        groups="hr.group_hr_manager"/>

    <!-- Configuration Root -->
    <menuitem 
        id="menu_ahadu_attendance_configuration_root" 
        name="Configuration" 
        parent="hr_attendance.menu_hr_attendance_root"
        sequence="100" 
        groups="hr.group_hr_manager"/>


    <!-- ======================================================
         2. DEFINE ACTIONS AND SUB-MENUS
         ====================================================== -->

    <!-- Dashboard -->
    <record id="action_attendance_dashboard" model="ir.actions.client">
        <field name="name">Ahadu Dashboard</field>
        <field name="tag">ahadu_attendance.dashboard</field>
    </record>

    <menuitem 
        id="menu_ahadu_dashboard"
        name="Dashboard"
        parent="hr_attendance.menu_hr_attendance_root"
        action="action_attendance_dashboard"
        sequence="1"/>

    <!-- Management Sub-menus -->
    <menuitem
        id="menu_ahadu_my_attendance"
        name="My Attendance"
        parent="ahadu_attendance.menu_ahadu_management_root"
        action="ahadu_attendance.action_my_attendance"
        sequence="1"/>

    <menuitem
        id="menu_hr_attendance_policy"
        name="Attendance Policies"
        parent="ahadu_attendance.menu_ahadu_management_root"
        action="ahadu_attendance.action_hr_attendance_policy"
        sequence="3"
        groups="hr.group_hr_manager"/>
    
    <menuitem
        id="menu_hr_attendance_policy_allocation"
        name="Policy Allocations"
        parent="ahadu_attendance.menu_ahadu_management_root"
        action="ahadu_attendance.action_hr_attendance_policy_allocation"
        sequence="4"
        groups="hr.group_hr_manager"/>

    <menuitem
        id="menu_ab_hr_attendance_sheet"
        name="Attendance Sheets"
        parent="ahadu_attendance.menu_ahadu_management_root"
        action="ahadu_attendance.action_ab_hr_attendance_sheet"
        sequence="5"
        groups="hr.group_hr_manager"/>

    <menuitem
        id="menu_hr_attendance_lateness_reason"
        name="Lateness Reasons"
        parent="ahadu_attendance.menu_ahadu_management_root"
        action="ahadu_attendance.action_ab_hr_attendance_lateness_reason"
        sequence="6"
        groups="hr.group_hr_manager"/>

    <menuitem
        id="menu_ab_hr_disciplinary_note"
        name="Disciplinary Notes"
        parent="ahadu_attendance.menu_ahadu_management_root"
        action="ahadu_attendance.action_ab_hr_disciplinary_note"
        sequence="7"
        groups="hr.group_hr_manager"/>

    <menuitem
        id="menu_ab_hr_overtime_policy"
        name="Overtime Policies"
        parent="ahadu_attendance.menu_ahadu_management_root"
        action="ahadu_attendance.action_ab_hr_overtime_policy"
        sequence="8"
        groups="hr.group_hr_manager"/>

    <menuitem
        id="menu_ab_hr_unplanned_absence"
        name="Unplanned Absences"
        parent="ahadu_attendance.menu_ahadu_management_root"
        action="action_ab_hr_unplanned_absence"
        sequence="10"
        groups="hr.group_hr_manager"/>

    <!-- Configuration Sub-menus (Parent exists now!) -->
    <menuitem
        id="menu_ahadu_shift_types"
        name="Shift Types"
        parent="ahadu_attendance.menu_ahadu_attendance_configuration_root"
        action="ahadu_attendance.action_ab_hr_shift_type"
        sequence="1"/>

    <menuitem
        id="menu_ahadu_shift_schedule"
        name="Shift Schedule"
        parent="ahadu_attendance.menu_ahadu_attendance_configuration_root"
        action="ahadu_attendance.action_ab_hr_shift_schedule"
        sequence="2"/>

    <menuitem
        id="menu_ahadu_mass_shift_schedule"
        name="Mass Shift Schedule"
        parent="ahadu_attendance.menu_ahadu_attendance_configuration_root"
        action="action_launch_shift_mass_schedule_wizard"
        sequence="10"/>

    <!-- My Requests Sub-menus -->
    <menuitem
        id="menu_ahadu_overtime_requests"
        name="Overtime Requests"
        parent="menu_ahadu_my_requests_root"
