<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 
            Create a single, persistent record for our API Manager.
            This gives our cron jobs a stable record to call.
        -->
        <record id="biotime_api_manager_main" model="biotime.api.manager">
            <field name="name">Default BioTime API Manager</field>
        </record>

        <record id="ir_cron_sync_attendance_from_biotime" model="ir.cron">
            <field name="name">BioTime: Pull Attendance Data</field>
            <field name="model_id" ref="ahadu_attendance.model_biotime_api_manager"/>
            <field name="state">code</field>
            <!-- Use env.ref() which is available in the eval context -->
            <field name="code">env.ref('ahadu_attendance.biotime_api_manager_main').sync_attendance_from_biotime()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>

        <record id="ir_cron_sync_employees_to_biotime" model="ir.cron">
            <field name="name">BioTime: Push Employee Data</field>
            <field name="model_id" ref="ahadu_attendance.model_biotime_api_manager"/>
            <field name="state">code</field>
            <!-- Use env.ref() which is available in the eval context -->
            <field name="code">env.ref('ahadu_attendance.biotime_api_manager_main').sync_employees_to_biotime()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="False"/>
        </record>
        <record id="ir_cron_auto_sync_biotime_attendance" model="ir.cron">
            <field name="name">Auto Sync BioTime Attendance</field>
            <field name="model_id" ref="ahadu_attendance.model_biotime_api_manager"/>
            <field name="state">code</field>
            <field name="code">model.cron_auto_sync_attendance()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <!-- <field name="numbercall">-1</field>
            <field name="doall" eval="False"/> -->
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>