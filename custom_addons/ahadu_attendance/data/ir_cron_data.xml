<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_update_employee_calendars" model="ir.cron">
            <field name="name">Shift Roster: Update Employee Calendars Daily</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model.search([('active', '=', True)])._update_employee_calendars_from_roster()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 01:00:00')" />
        </record>
        <record id="ir_cron_check_absences_and_warnings" model="ir.cron">
            <field name="name">Attendance: Check Absences &amp; Send Warnings</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._check_unplanned_absences_and_warnings()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 02:00:00')" />
        </record>
        <record id="ir_cron_check_missed_outs" model="ir.cron">
            <field name="name">Attendance: Check for Missed Check-outs</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_missed_outs()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 03:00:00')" />
        </record>
        <record id="ir_cron_auto_miss_out" model="ir.cron">
            <field name="name">Attendance: Auto Mark Missed Check-outs</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_missed_outs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 04:00:00')" />
        </record>
    </data>
</odoo>