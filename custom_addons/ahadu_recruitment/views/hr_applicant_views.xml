<odoo>
    <record id="hr_applicant_view_form_inherit_ahadu" model="ir.ui.view">
        <field name="name">hr.applicant.form.inherit.custom</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
           
          <xpath expr="//field[@name='email_from']" position="before">
          <field name="employee_id"
           modifiers='{
               "invisible": [["stage_id.name", "!=", "Contract Signed"]],
               "required": [["stage_id.name", "=", "Contract Signed"]]
           }'/>
          </xpath>


             <!-- Insert new fields after 'Partner Phone' -->
            <xpath expr="//field[@name='partner_phone']" position="after">
                <field name="age"/>
                <field name="gender"/>
            </xpath>
            
            <!-- LinkedIn profile not required -->
            <xpath expr="//field[@name='linkedin_profile']" position="attributes">
                <attribute name="required">0</attribute>
            </xpath>
            
            <!-- Add custom groups -->
            <xpath expr="//group[@name='recruitment_contract']" position="after">
                <group string="Educational Details">
                    <field name="educational_qualification"/>
                    <field name="institution_name"/>
                </group>
                <group string="Current Employment Details">
                    <field name="current_position"/>
                    <field name="years_in_current_position"/>
                    <field name="current_employer"/>
                    <field name="current_salary" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                    <field name="salary_expectation" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                </group>
                <group string="Experience &amp; Location">
                    <field name="total_years_banking_exp"/>
                    <field name="current_location"/>
                    <!-- <field name="preferred_location"/> -->
                </group>
                <group string="Application Documents">
                    <field name="application_documents" widget="many2many_binary"/>
                </group>
            </xpath>
            
            <xpath expr="//field[@name='categ_ids']" position="after">
                <label for="interview_score" string="Interview Score" invisible="not stage_id.is_last_interview_stage"/>
                <div class="o_row" invisible="not stage_id.is_last_interview_stage">
                    <field name="interview_score" nolabel="1"/>
                    <span class="ms-1 me-1">%</span>
                    <field name="interview_rating" widget="priority" nolabel="1" class="ms-2"/>
                </div>

                <!-- Written Exam Score -->
                <label for="written_exam_score" string="Written Exam Score" invisible="not stage_id.is_last_interview_stage"/>
                <div class="o_row" invisible="not stage_id.is_last_interview_stage">
                    <field name="written_exam_score" nolabel="1"/>
                    <span class="ms-1 me-1">%</span>
                </div>

               <!-- Average Score with Color -->
               <label for="combined_score" string="Average Score" invisible="not stage_id.is_last_interview_stage"/>
               <div class="o_row" invisible="not stage_id.is_last_interview_stage">
                   <field name="combined_score" nolabel="1" readonly="1"/>
                   <span class="ms-1 me-1">%</span>
                   <!-- <field name="score_color" widget="statusbar" nolabel="1"/> -->
               </div>
            </xpath>
        </field>
    </record>
</odoo>
