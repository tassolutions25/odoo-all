<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ahadu_leave_type_annual" model="hr.leave.type">
            <field name="name">Annual Leave</field>
            <field name="requires_allocation">yes</field>
            <field name="employee_requests">yes</field>
            <field name="leave_validation_type">manager</field>
            <field name="request_unit">day</field>
        </record>

        <!-- THE FIX: All of these now correctly require an allocation -->
        <record id="ahadu_leave_type_paternity" model="hr.leave.type">
            <field name="name">Paternity Leave</field>
            <field name="requires_allocation">yes</field>
            <field name="employee_requests">yes</field>
            <field name="leave_validation_type">manager</field>
            <field name="request_unit">day</field>
        </record>

        <record id="ahadu_leave_type_maternity" model="hr.leave.type">
            <field name="name">Maternity Leave</field>
            <field name="requires_allocation">yes</field>
            <field name="employee_requests">yes</field>
            <field name="leave_validation_type">manager</field>
            <field name="request_unit">day</field>
            <field name="support_document">True</field>
        </record>

        <record id="ahadu_leave_type_marriage" model="hr.leave.type">
            <field name="name">Marriage Leave</field>
            <field name="requires_allocation">yes</field>
            <field name="employee_requests">yes</field>
            <field name="leave_validation_type">manager</field>
            <field name="request_unit">day</field>
        </record>

        <record id="ahadu_leave_type_bereavement" model="hr.leave.type">
            <field name="name">Bereavement Leave</field>
            <field name="requires_allocation">yes</field>
            <field name="employee_requests">yes</field>
            <field name="leave_validation_type">manager</field>
            <field name="request_unit">day</field>
        </record>

        <record id="ahadu_sick_leave_request" model="hr.leave.type">
            <field name="name">Sick Leave</field>
            <field name="requires_allocation">yes</field>
            <field name="employee_requests">yes</field>
            <field name="leave_validation_type">both</field>
            <field name="request_unit">day</field>
            <field name="support_document">True</field>
        </record>

        <!-- This one is correct, it does NOT require allocation -->
        <record id="ahadu_leave_type_lwop" model="hr.leave.type">
            <field name="name">Leave Without Pay</field>
            <field name="requires_allocation">no</field>
            <field name="employee_requests">yes</field>
            <field name="leave_validation_type">both</field>
            <field name="request_unit">day</field>
            <field name="unpaid" eval="True" />
        </record>

    </data>
</odoo>