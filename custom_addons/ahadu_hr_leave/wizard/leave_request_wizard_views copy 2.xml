<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ahadu_leave_request_wizard_view_form" model="ir.ui.view">
        <field name="name">ahadu.leave.request.wizard.form.unified</field>
        <field name="model">ahadu.leave.request.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="alert alert-info" role="alert"> Select a specific <strong>Leave
                        Balance</strong> to deduct from, or choose a <strong>Leave Type</strong>
                        directly for other leaves like Leave Without Pay. </div>
                    <group>
                        <field name="allocation_id"
                            placeholder="Select a balance (e.g., Annual, Sick...)"
                            options="{'no_create': True, 'no_open': True}"
                            context="{'employee_id': employee_id}" />
                        <field name="holiday_status_id"
                            options="{'no_create': True, 'no_open': True}"
                            readonly="allocation_id != False"
                            force_save="1" />
                        <field name="available_days"
                            invisible="not holiday_status_id or not holiday_status_id.requires_allocation == 'yes'" />
                    </group>
                    <group>
                        <label for="request_date_from" string="Dates (Gregorian)" />
                        <div class="o_row">
                            <field name="request_date_from" nolabel="1" />
                            <span>→</span>
                            <field name="request_date_to" nolabel="1" />
                        </div>
                        <label for="ethiopian_date_from" string="Dates (Ethiopian)" />
                        <div class="o_row text-muted">
                            <field name="ethiopian_date_from" nolabel="1" />
                            <span>→</span>
                            <field name="ethiopian_date_to" nolabel="1" />
                        </div>
                        <field name="number_of_days" readonly="1" force_save="1" />
                        <field name="name" string="Description" placeholder="Add a description..." />

                        <field name="is_attachment_mandatory" invisible="1" />
                        <field name="attachment_ids" widget="many2many_binary"
                            string="Supporting Document"
                            invisible="not is_attachment_mandatory" />
                    </group>
                </sheet>
                <footer>
                    <button name="action_submit_request" string="Submit" type="object"
                        class="btn-primary" />
                    <button string="Discard" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ahadu_leave_request_wizard" model="ir.actions.act_window">
        <field name="name">New Leave Request</field>
        <field name="res_model">ahadu.leave.request.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>