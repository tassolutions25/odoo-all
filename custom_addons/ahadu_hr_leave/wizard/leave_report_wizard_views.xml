<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ahadu_leave_report_wizard_form" model="ir.ui.view">
        <field name="name">ahadu.leave.report.wizard.form</field>
        <field name="model">ahadu.leave.report.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="report_type" widget="radio" />
                    </group>
                    <group>
                        <field name="date_from" />
                        <field name="date_to" />
                    </group>
                </group>
                <group string="Filters">
                    <group>
                        <field name="employee_ids" widget="many2many_tags" 
                               groups="ahadu_hr_leave.group_leave_officer,hr_holidays.group_hr_holidays_manager" />
                        <field name="department_ids" widget="many2many_tags" 
                               groups="ahadu_hr_leave.group_leave_officer,hr_holidays.group_hr_holidays_manager" />
                        <field name="is_hr_officer" invisible="1" />
                    </group>
                    <group>
                        <field name="leave_type_ids" widget="many2many_tags" 
                               invisible="report_type not in ['balance', 'request']" />
                        <field name="status" 
                               invisible="report_type != 'request'" />
                    </group>
                </group>
                <group string="Report Preview" invisible="not show_preview">
                    <field name="show_preview" invisible="1"/>
                    <field name="preview_line_ids" nolabel="1">
                        <list create="0" delete="0" edit="0">
                            <field name="col1" string="Employee" column_invisible="parent.report_type == 'approval'"/>
                            <field name="col1" string="Manager" column_invisible="parent.report_type != 'approval'"/>
                            <field name="col1" string="Month" column_invisible="parent.report_type != 'trend'"/>

                            <field name="col2" string="Leave Type" column_invisible="parent.report_type != 'balance'"/>
                            <field name="col2" string="Leave Type" column_invisible="parent.report_type != 'request'"/>
                            <field name="col2" string="Issue" column_invisible="parent.report_type != 'audit'"/>
                            <field name="col2" string="Days" column_invisible="parent.report_type != 'trend'"/>
                            <field name="col2" string="Pending" column_invisible="parent.report_type != 'approval'"/>

                            <field name="col3" string="Allocated" column_invisible="parent.report_type != 'balance'"/>
                            <field name="col3" string="Start Date" column_invisible="parent.report_type != 'request'"/>
                            <field name="col3" string="Details" column_invisible="parent.report_type != 'audit'"/>
                            <field name="col3" string="Approved" column_invisible="parent.report_type != 'approval'"/>

                            <field name="col4" string="Used" column_invisible="parent.report_type != 'balance'"/>
                            <field name="col4" string="End Date" column_invisible="parent.report_type != 'request'"/>

                            <field name="col5" string="Remaining" column_invisible="parent.report_type != 'balance'"/>
                            <field name="col5" string="Status" column_invisible="parent.report_type != 'request'"/>
                        </list>
                    </field>
                </group>
                <footer>
                    <button name="action_preview" string="Preview" type="object" class="btn-primary" />
                    <button name="action_print_report" string="Generate PDF" type="object" class="btn-secondary" />
                    <button string="Close" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ahadu_leave_report_wizard" model="ir.actions.act_window">
        <field name="name">Leave Master Reports</field>
        <field name="res_model">ahadu.leave.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_ahadu_leave_reporting_master"
              name="Master Reports"
              parent="menu_hr_holidays_report"
              action="action_ahadu_leave_report_wizard"
              sequence="5" />
</odoo>
