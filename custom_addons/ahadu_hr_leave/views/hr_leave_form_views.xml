<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_view_form_inherit_partial_cancel" model="ir.ui.view">
        <field name="name">hr.leave.form.inherit.partial.cancel</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form" />
        <field name="arch" type="xml">
            <!--
                We use a single, stable xpath to target the header.
            -->
            <xpath expr="//header" position="inside">
                <!--
                    Step 1: Add the new computed field to the view (invisibly).
                    Its value is now available to any element inside the header.
                -->
                <field name="can_partial_cancel" invisible="1" />

                <!--
                    Step 2: Add the button and bind its visibility to the new field.
                    This uses the cleaner Odoo 17/18 syntax.
                -->
                <button name="%(ahadu_hr_leave.action_ahadu_leave_partial_cancel_wizard)d"
                    string="Partial Cancel"
                    type="action"
                    class="btn-secondary"
                    invisible="not can_partial_cancel"
                    groups="hr_holidays.group_hr_holidays_manager,hr_holidays.group_hr_holidays_responsible" />
            </xpath>
        </field>
    </record>
</odoo>