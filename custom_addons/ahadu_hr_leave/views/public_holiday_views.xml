    </record> -->

    <!-- Action to open the Public Holidays views -->
    <record id="public_holiday_action" model="ir.actions.act_window">
        <field name="name">Public Holidays</field>
        <field name="res_model">ahadu.public.holiday</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new public holiday.
            </p>
            <p>
                Define the public holidays for your company. These will be automatically excluded
                from Leave calculations.
            </p>
        </field>
    </record>

