<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_leave_allocation_view_form_inherit_ahadu" model="ir.ui.view">
        <field name="name">hr.leave.allocation.form.inherit.ahadu</field>
        <field name="model">hr.leave.allocation</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_form_manager" />
        <field name="arch" type="xml">
            <field name="date_to" position="after">
                <field name="date_from" />
                <field name="expiry_date" />
                <field name="expired_leaves" />
            </field>
        </field>
    </record>

    <record id="hr_leave_allocation_view_tree_inherit_ahadu" model="ir.ui.view">
        <field name="name">hr.leave.allocation.tree.inherit.ahadu</field>
        <field name="model">hr.leave.allocation</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_tree" />
        <field name="arch" type="xml">
            <!--
                [PROACTIVE FIX IS HERE]
                The XPath now uses the correct Odoo 18 field name: 'remaining_leaves'.
            -->
            <xpath expr="//field[@name='remaining_leaves']" position="after">
                <field name="date_of_joining" optional="show" />
                <field name="expiry_date" optional="show" />
                <field name="expired_leaves" optional="show" />
            </xpath>
        </field>
    </record>

</odoo>