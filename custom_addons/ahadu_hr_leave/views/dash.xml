<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- The Kanban View with proper spacing -->
    <record id="hr_leave_dashboard_view_kanban" model="ir.ui.view">
        <field name="name">hr.leave.dashboard.kanban.styled</field>
        <field name="model">ahadu.hr.leave.dashboard</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_view_dashboard" create="false" records_draggable="false"
                banner_route="false">
                <field name="id" />
                <templates>
                    <t t-name="kanban-box">
                        <div class="container-fluid o_dashboard_leave p-3">
                            <div class="row">

                                <!-- Card 1: My Allocation -->
                                <!-- The p-2 class adds padding around the column, creating the
                                space -->
                                <div class="col-lg-3 col-md-6 p-2">
                                    <button name="action_open_my_allocations" type="object"
                                        class="card-dashboard-button card-allocations">
                                        <i class="fa fa-calendar-plus-o fa-3x" />
                                        <h4>My Allocation</h4>
                                    </button>
                                </div>

                                <!-- Card 2: My Leaves -->
                                <div class="col-lg-3 col-md-6 p-2">
                                    <button name="action_open_my_time_off" type="object"
                                        class="card-dashboard-button card-time-off">
                                        <i class="fa fa-calendar fa-3x" />
                                        <h4>My Leaves</h4>
                                    </button>
                                </div>

                                <!-- Card 3: Overview -->
                                <div class="col-lg-3 col-md-6 p-2">
                                    <button name="action_open_overview" type="object"
                                        class="card-dashboard-button card-overview">
                                        <i class="fa fa-bar-chart fa-3x" />
                                        <h4>Overview</h4>
                                    </button>
                                </div>

                                <!-- Card 4: Calendar -->
                                <div class="col-lg-3 col-md-6 p-2">
                                    <button name="action_open_calendar" type="object"
                                        class="card-dashboard-button card-calendar">
                                        <i class="fa fa-calendar-o fa-3x" />
                                        <h4>Calendar</h4>
                                    </button>
                                </div>

                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action and Menus (No changes needed here) -->
    <record id="hr_leave_dashboard_action" model="ir.actions.act_window">
        <field name="name">Leave Dashboard</field>
        <field name="res_model">ahadu.hr.leave.dashboard</field>
        <field name="view_mode">kanban</field>
    </record>
    <menuitem id="ahadu_hr_leave_menu_root" name="Ahadu Leave" action="hr_leave_dashboard_action"
        sequence="10" />
    <menuitem id="ahadu_hr_leave_dashboard_submenu" name="Dashboard"
        parent="ahadu_hr_leave_menu_root" action="hr_leave_dashboard_action" sequence="1" />

</odoo>