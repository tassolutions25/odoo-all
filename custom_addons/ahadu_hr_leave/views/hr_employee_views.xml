<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        This record adds the Leave Entitlement Class directly after
        the 'Position Classification' field inside the 'Work Information' tab.
        This is the definitive and correct placement based on your screenshot.
    -->
    <record id="hr_employee_view_form_inherit_leave_class_ahadu" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.leave.class.ahadu</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form" />
        <field name="arch" type="xml">
            <!--
                THE FIX: Find the 'position_classification' field, which we can
                see in the screenshot, and place our new field right after it.
            -->
            <xpath expr="//page[@name='hr_settings']//field[@name='employee_type']" position="after">
                <field name="leave_entitlement_class" />
            </xpath>
        </field>
    </record>

