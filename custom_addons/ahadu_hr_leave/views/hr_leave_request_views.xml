<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
    Step 1: Define our custom "wizard-style" form view for the 'hr.leave' model.
    This version has NO custom header or footer, allowing Odoo's default save
    and workflow buttons to work correctly.
    -->
    <record id="ahadu_hr_leave_request_view_form_wizard" model="ir.ui.view">
        <field name="name">ahadu.hr.leave.request.wizard.form</field>
        <field name="model">hr.leave</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <form>
                <!-- By having NO header or footer, we let Odoo control the save/submit process -->
                <sheet>
                    <group>
                        <field name="employee_id" readonly="1" force_save="1" />
                        <field name="holiday_status_id" invisible="1" />
                        <field name="allocation_id"
                            placeholder="For Annual, Paternity, etc."
                            domain="[('employee_id', '=', employee_id), ('state', '=', 'validate'), ('effective_remaining_leaves', '>', 0)]"
                            context="{'employee_id': employee_id}" />
                        <field name="holiday_status_id"
                            string="Leave Type"
                            placeholder="For leaves without a balance..."
                            context="{'employee_id': employee_id, 'show_leaves_not_requiring_allocation': True}"
                            invisible="allocation_id" />
                        <label for="request_date_from" string="Dates" />
                        <div class="o_row">
                            <field name="request_date_from" nolabel="1" />
                            <span>-</span>
                            <field name="request_date_to" nolabel="1" />
                        </div>
                        <field name="number_of_days" readonly="1" force_save="1" />
                    </group>
                    <group string="Details">
                        <field name="name" nolabel="1"
                            placeholder="Provide a reason for your request..." />
                    </group>
                </sheet>
                <!-- The chatter will appear automatically after the record is first saved -->
                <div class="oe_chatter" />
            </form>
        </field>
    </record>

    <!--
    Step 2: Create our Window Action that uses the custom form (Unchanged)
    -->
    <record id="action_ahadu_my_time_off_with_wizard" model="ir.actions.act_window">
        <field name="name">My Leaves</field>
        <field name="res_model">hr.leave</field>
        <field name="view_mode">tree,calendar,form</field>
        <field name="context">{'search_default_my_leaves': 1, 'search_default_year': 1}</field>
        <field name="domain">[('employee_id', '!=', False)]</field>

    </record>

    <!--
    Step 3: Override the standard "My Leaves" menu item to call OUR action (Unchanged)
    -->
    <menuitem
        id="hr_holidays.hr_leave_menu_my"
        parent="hr_holidays.menu_hr_holidays_my_leaves"
        action="ahadu_hr_leave.action_ahadu_my_time_off_with_wizard"
        sequence="1" />

</odoo>