<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
    This view modification adds our new wizard button to the top of the "My Leaves" list
    and disables the original "New" button.
    -->
    <record id="hr_leave_view_tree_my_with_wizard_button" model="ir.ui.view">
        <field name="name">hr.leave.tree.my.wizard</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree_my" />
        <field name="arch" type="xml">
            <!-- Disable the default 'New' button in the list view -->
            <xpath expr="//list" position="attributes">
                <attribute name="create">false</attribute>
            </xpath>
            <!-- Add a header bar above the list with our custom button -->
            <xpath expr="//list" position="before">
                <header>
                    <button name="%(ahadu_hr_leave.action_ahadu_leave_request_wizard)d"
                        string="New Request" type="action" class="btn-primary" />
                </header>
            </xpath>
        </field>
    </record>

    <record id="hr_leave_view_form_manager_inherit_cancel" model="ir.ui.view">
        <field name="name">hr.leave.view.form.manager.inherit.cancel</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager" />
        <field name="arch" type="xml">
            <!-- Add new buttons to the header -->
            <xpath expr="//header" position="inside">
                <!-- Employee's button to withdraw a submitted request -->
                <button name="action_withdraw" string="Withdraw Request" type="object"
                    class="btn-secondary" invisible="state != 'confirm'" />

                <!-- Employee's button to request cancellation of an approved leave -->
                <button name="action_request_cancel" string="Request Cancellation" type="object"
                    class="btn-warning" invisible="state != 'validate'" />

                <!-- Manager's buttons to handle the cancellation request -->
                <button name="action_approve_cancel" string="Approve Cancellation" type="object"
                    class="btn-success" invisible="state != 'to_cancel'"
                    groups="hr_holidays.group_hr_holidays_user" />
                <button name="action_reject_cancel" string="Reject Cancellation" type="object"
                    class="btn-danger" invisible="state != 'to_cancel'"
                    groups="hr_holidays.group_hr_holidays_user" />
            </xpath>

            <!-- Add the new state to the status bar for visibility -->
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">draft,confirm,to_cancel,validate</attribute>
            </xpath>
        </field>
    </record>

    <record id="hr_leave_view_form_inherit_partial_cancel" model="ir.ui.view">
        <field name="name">hr.leave.form.inherit.partial.cancel</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(ahadu_hr_leave.action_ahadu_leave_partial_cancel_wizard)d"
                    string="Partial Cancel"
                    type="action"
                    class="btn-secondary"
                    invisible="['|', ('state', '!=', 'validate'), ('request_date_to', '&lt;', context_today().strftime('%Y-%m-%d'))]" />
            </xpath>
        </field>
    </record>
</odoo>