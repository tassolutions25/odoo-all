<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Create a simple form view for our leave settings -->
    <record id="view_ahadu_leave_configuration" model="ir.ui.view">
        <field name="name">ahadu.leave.configuration.form</field>
        <field name="model">res.config.settings</field>
        <field name="priority">100</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Ahadu Leave" name="ahadu_hr_leave" groups="hr_holidays.group_hr_holidays_manager">
                    <block title="Leave Allocation">
                        <setting>
                            <field name="auto_allocate_leaves"/>
                            <div class="content-group">
                                <div class="text-muted">
                                    Automatically create leave allocations (Paternity, Maternity, Sick, etc.) when employees are created or updated
                                </div>
                            </div>
                        </setting>
                        <setting string="Accrual Launch Date">
                            <field name="accrual_launch_date"/>
                            <div class="content-group">
                                <div class="text-muted">
                                    Set the date when automatic annual leave accrual should start. Employees hired before this date will start accruing from this date (not from their joining date).
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
