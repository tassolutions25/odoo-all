<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================================ -->
        <!--  RECORD RULES: Employee / Manager / HR Admin                  -->
        <!-- ============================================================ -->

        <!-- Rule: Employees see only their own On-Duty records -->
        <record id="rule_on_duty_employee_own" model="ir.rule">
            <field name="name">On-Duty: Employee Own Records</field>
            <field name="model_id" ref="model_hr_on_duty"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('ahadu_attendance.group_ahadu_attendance_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Rule: Managers see their department's On-Duty records -->
        <record id="rule_on_duty_manager_department" model="ir.rule">
            <field name="name">On-Duty: Manager Department Records</field>
            <field name="model_id" ref="model_hr_on_duty"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('ahadu_attendance.group_ahadu_attendance_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Rule: HR Admin sees all records (no domain restriction) -->
        <record id="rule_on_duty_hr_admin_all" model="ir.rule">
            <field name="name">On-Duty: HR Admin All Records</field>
            <field name="model_id" ref="model_hr_on_duty"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('ahadu_attendance.group_ahadu_attendance_hr_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
