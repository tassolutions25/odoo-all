<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- RESIGNATION PAYSLIP VIEW -->
    <record id="view_hr_resignation_payslip_list" model="ir.ui.view">
        <field name="name">hr.resignation.payslip.list</field>
        <field name="model">hr.resignation.payslip</field>
        <field name="arch" type="xml">
            <list string="Resignation Payslips">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="resignation_date"/>
                <field name="leave_days"/>
                <field name="leave_pay_net" sum="Total Leave Pay"/>
                <field name="net_payable" sum="Total Payable"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'calculated'" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_hr_resignation_payslip_form" model="ir.ui.view">
        <field name="name">hr.resignation.payslip.form</field>
        <field name="model">hr.resignation.payslip</field>
        <field name="arch" type="xml">
            <form string="Resignation Payslip">
                <header>
                    <button name="compute_sheet" string="Compute" type="object" class="oe_highlight" invisible="state != 'draft'" groups="payroll.group_payroll_user"/>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'calculated'" groups="payroll.group_payroll_manager"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state == 'done'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,calculated,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" context="{'active_test': False}"/>
                            <field name="resignation_date"/>
                            <field name="prepared_by_id"/>
                            <field name="approved_by_id"/>
                        </group>
                        <group>
                            <field name="wage"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Leave Pay">
                            <group>
                                <group string="Calculation">
                                    <field name="leave_days"/>
                                    <field name="leave_pay_gross"/>
                                    <field name="leave_pay_tax"/>
                                    <field name="leave_pay_net" class="oe_subtotal_footer_separator"/>
                                </group>
                            </group>
                        </page>
                        <page string="Salary &amp; Benefits">
                            <group>
                                <group string="Unpaid Earnings">
                                    <field name="present_days"/>
                                    <field name="unpaid_salary"/>
                                    <field name="representation_allowance"/>
                                    <field name="unpaid_transport"/>
                                    <field name="unpaid_housing"/>
                                    <field name="unpaid_mobile"/>
                                    <field name="gross_amount" class="oe_subtotal_footer_separator"/>
                                </group>
                                <group string="Taxes &amp; Deductions">
                                    <field name="taxable_amount"/>
                                    <field name="tax_salary"/>
                                    <field name="grand_tax" class="oe_subtotal_footer_separator"/>
                                    
                                    <separator string="Pension"/>
                                    <field name="pension_emp"/>
                                    <field name="pension_comp"/>
                                    
                                    <separator string="Other Deductions"/>
                                    <field name="lost_id_card"/>
                                    <field name="vat_on_id_card"/>
                                    <field name="other_deductions"/>
                                    
                                    <field name="total_deduction" class="oe_subtotal_footer_separator"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                    <group class="oe_subtotal_footer oe_right">
                        <field name="net_payable" class="oe_subtotal_footer_separator"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ACTIONS -->
    <record id="action_hr_resignation_payslip" model="ir.actions.act_window">
        <field name="name">Resignation Payslips</field>
        <field name="res_model">hr.resignation.payslip</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENUS -->
    <menuitem id="menu_hr_resignation_root" 
              name="Resignation" 
              parent="ahadu_payroll.menu_ahadu_root" 
              groups="payroll.group_payroll_user,payroll.group_payroll_manager"
              sequence="31"/>

    <menuitem id="menu_hr_resignation_payslip" 
              name="Resignation Payslips" 
              parent="menu_hr_resignation_root" 
              action="action_hr_resignation_payslip" 
              groups="payroll.group_payroll_user,payroll.group_payroll_manager"
              sequence="20"/>

</odoo>
