<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ahadu_payroll_tax_bracket_tree" model="ir.ui.view">
        <field name="name">ahadu.payroll.tax.bracket.tree</field>
        <field name="model">ahadu.payroll.tax.bracket</field>
        <field name="arch" type="xml">
            <list editable="bottom" decoration-muted="not active">
                <field name="lower_bound"/>
                <field name="upper_bound"/>
                <field name="rate"/>
                <field name="deduction"/>
                <field name="display_range"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_ahadu_payroll_tax_bracket" model="ir.actions.act_window">
        <field name="name">Income Tax Brackets</field>
        <field name="res_model">ahadu.payroll.tax.bracket</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define the Ethiopian Income Tax Brackets.
            </p>
        </field>
    </record>
</odoo>
