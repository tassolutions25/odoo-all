<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- LIST VIEW -->
    <record id="view_ahadu_journal_entry_tree" model="ir.ui.view">
        <field name="name">ahadu.journal.entry.list</field>
        <field name="model">ahadu.journal.entry</field>
        <field name="arch" type="xml">
            <list string="Journal Entries" create="0" edit="0" delete="0">
                <field name="date" />
                <field name="name" />
                <field name="payslip_run_id" />
                <field name="state" widget="badge" decoration-success="state == 'posted'" />
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_ahadu_journal_entry_form" model="ir.ui.view">
        <field name="name">ahadu.journal.entry.form</field>
        <field name="model">ahadu.journal.entry</field>
        <field name="arch" type="xml">
            <form string="Journal Entry" create="0" edit="0" delete="0">
                <header>
                    <button name="%(action_report_journal_entry_ahadu)d" string="Print Journal Entry" type="action" class="oe_highlight"/>
                    <field name="state" widget="statusbar" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" />
                            <field name="payslip_run_id" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Journal Lines">
                            <field name="line_ids">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="account_id" />
                                    <field name="description" />
                                    <field name="cost_center_id" />
                                    <field name="debit" sum="Total Debit" />
                                    <field name="credit" sum="Total Credit" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_ahadu_journal_entry" model="ir.actions.act_window">
        <field name="name">Journal Entries</field>
        <field name="res_model">ahadu.journal.entry</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem
        id="menu_ahadu_journal_entry"
        name="Journal Entries"
        parent="menu_ahadu_operations"
        action="action_ahadu_journal_entry"
        sequence="30" />
</odoo>