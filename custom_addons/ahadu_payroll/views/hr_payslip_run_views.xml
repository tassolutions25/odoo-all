<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_payslip_run_form_inherit_ahadu" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.inherit.ahadu</field>
        <field name="model">hr.payslip.run</field>
        <!-- CHANGED THE REF ID BELOW -->
        <field name="inherit_id" ref="payroll.hr_payslip_run_view_form" />
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <!-- Button: Generate Filtered Payslips -->
                <button name="action_generate_payslips_filtered" type="object" 
                    string="Generate Filtered Payslips"
                    invisible="state != 'draft' or (not pay_group_ids and not cost_center_ids and not branch_ids and not region_ids and not department_ids)" 
                    class="oe_highlight" />

                <!-- Button: Submit to Manager (Visible to Officer in Draft) -->
                <button name="action_verify" type="object" string="Submit for Verification"
                    invisible="state != 'draft'" class="oe_highlight" />

                <!-- Button: Approve/Close (Visible ONLY to Manager in Verify) -->
                <button name="close_payslip_run" type="object" string="Approve &amp; Close"
                    invisible="state != 'verify'"
                    groups="payroll.group_payroll_manager" class="oe_highlight" />

                <!-- Button: Reset to Draft (Visible ONLY to Manager in Verify) -->
                <button name="action_draft" type="object" string="Reject / Reset"
                    invisible="state != 'verify'"
                    groups="payroll.group_payroll_manager" />

                <!-- Bank Transfer File -->
                <button name="action_print_bank_transfer" type="object" string="Bank Transfer File"
                    invisible="state == 'draft'" class="oe_highlight" />

                <button name="action_print_pension_report" type="object" string="Pension Report"
                    invisible="state == 'draft'" />



                <button name="action_print_tax_declaration" type="object" string="Income Tax Declaration Form"
                    invisible="state == 'draft'" class="oe_highlight" />

                <button name="action_print_payroll_sheet_excel" type="object" string="Payroll Sheet (Excel)"
                    invisible="state == 'draft'" class="oe_highlight" />

                <button name="action_print_cost_sharing_report" type="object" string="Cost Sharing Report"
                    invisible="state == 'draft'" class="oe_highlight" />

                <button name="action_print_cash_indemnity_report" type="object" string="Cash Indemnity Report"
                    invisible="state == 'draft'" class="oe_highlight" />
            </xpath>

            <!-- Add the Status Bar -->
            <xpath expr="//field[@name='state']" position="replace">
                <field name="state" widget="statusbar" statusbar_visible="draft,verify,close" />
            </xpath>

            <!-- Add Pay Group, Cost Center, Branch, Region, and Department Filters at the end of the first group in sheet -->
            <xpath expr="//sheet//group" position="inside">
                <field name="pay_group_ids" widget="many2many_tags" 
                    placeholder="All Pay Groups (optional filter)" />
                <field name="cost_center_ids" widget="many2many_tags" 
                    placeholder="All Cost Centers (optional filter)" />
                <field name="branch_ids" widget="many2many_tags" 
                    placeholder="All Branches (optional filter)" />
                <field name="region_ids" widget="many2many_tags" 
                    placeholder="All Regions (optional filter)" />
                <field name="department_ids" widget="many2many_tags" 
                    placeholder="All Departments (optional filter)" />
            </xpath>

            <!-- Show employees in selected criteria -->
            <xpath expr="//field[@name='slip_ids']" position="before">
                <group string="Employees in Selected Criteria" invisible="not pay_group_ids and not cost_center_ids and not branch_ids and not region_ids and not department_ids">
                    <div class="alert alert-info" role="alert" colspan="2">
                        <strong><field name="employee_count" nolabel="1" class="oe_inline"/> employees</strong> found in the selected Pay Group(s) / Cost Center(s) / Branch(es) / Region(s) / Department(s).
                        Click <strong>"Generate Filtered Payslips"</strong> button to create payslips.
                    </div>
                    <field name="available_employee_ids" nolabel="1" colspan="2" readonly="1">
                        <list>
                            <field name="name" />
                            <field name="department_id" optional="show" />
                            <field name="job_id" optional="show" />
                        </list>
                    </field>
                </group>
            </xpath>

            <!-- Add filtered payslips section -->
            <xpath expr="//field[@name='slip_ids']" position="after">
                <group string="Generated Payslips (Filtered)" invisible="not pay_group_ids and not cost_center_ids and not branch_ids and not region_ids and not department_ids">
                    <field name="filtered_slip_ids" nolabel="1" colspan="2" readonly="1">
                        <list>
                            <field name="employee_id" />
                            <field name="number" optional="show" />
                            <field name="contract_id" optional="hide" />
                            <field name="state" widget="badge" 
                                decoration-info="state == 'draft'"
                                decoration-warning="state == 'verify'"
                                decoration-success="state == 'done'" />
                        </list>
                    </field>
                </group>

                <!-- Approval Tracking -->
                <group string="Approvals &amp; Tracking">
                    <group>
                        <field name="created_by_id" widget="many2one_avatar_user"/>
                        <field name="create_date" string="Created On" readonly="1"/>
                    </group>
                    <group>
                        <field name="approved_by_id" widget="many2one_avatar_user"/>
                        <field name="approved_date"/>
                        <field name="bank_transfer_done" widget="boolean_toggle"/>
                        <field name="cash_indemnity_done" widget="boolean_toggle"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>
</odoo>