<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Employee Deduction List View -->
    <record id="hr_employee_deduction_view_list" model="ir.ui.view">
        <field name="name">hr.employee.deduction.list</field>
        <field name="model">hr.employee.deduction</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="deduction_type"/>
                <field name="penalty_percentage" optional="show"/>
                <field name="monthly_amount"/>
                <field name="remaining_balance" optional="show"/>
                <field name="paid_installments" optional="hide"/>
                <field name="total_installments" optional="hide"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-muted="state == 'completed'" decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Employee Deduction Form View -->
    <record id="hr_employee_deduction_view_form" model="ir.ui.view">
        <field name="name">hr.employee.deduction.form</field>
        <field name="model">hr.employee.deduction</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_complete" string="Mark Completed" type="object" class="oe_highlight" invisible="state != 'active'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state != 'active'"/>
                    <button name="action_reactivate" string="Reactivate" type="object" invisible="state == 'active'"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g., Car Loan 2024"/></h1>
                    </div>
                    <group>
                        <group string="Basic Information">
                            <field name="employee_id"/>
                            <field name="deduction_type"/>
                            <field name="monthly_amount" invisible="deduction_type == 'penalty'"/>
                        </group>
                        <group string="Duration">
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group invisible="deduction_type != 'penalty'">
                        <group string="Penalty Details">
                            <field name="penalty_percentage" string="Penalty % of Basic Salary"/>
                            <field name="penalty_reason"/>
                        </group>
                    </group>

                    <group>
                        <field name="notes" placeholder="Additional notes about this deduction..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Inline List View for Employee Form Tab -->
    <record id="hr_employee_deduction_view_list_inline" model="ir.ui.view">
        <field name="name">hr.employee.deduction.list.inline</field>
        <field name="model">hr.employee.deduction</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="deduction_type"/>
                <field name="penalty_percentage" optional="show"/>
                <field name="monthly_amount"/>
                <field name="start_date"/>
                <field name="end_date" optional="hide"/>

                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Action for Employee Deductions -->
    <record id="hr_employee_deduction_action" model="ir.actions.act_window">
        <field name="name">Employee Deductions</field>
        <field name="res_model">hr.employee.deduction</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first employee deduction</p>
            <p>Manage loan repayments, savings, and other deductions for employees.</p>
        </field>
    </record>

    <!-- THE MENU FIX: Un-commented and linked safely -->
    <menuitem id="menu_hr_employee_deduction"
        name="Deductions"
        parent="ahadu_payroll.menu_ahadu_config_root"
        action="hr_employee_deduction_action"
        groups="ahadu_payroll.group_ahadu_payroll_finance_officer,base.group_system"
        sequence="50"/>

    <!-- Add Deductions TAB on Employee Form (like Benefits and Allowances) -->
    <record id="hr_employee_form_inherit_deductions" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.deductions</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Deductions &amp; Loans" name="deductions">
                    <group string="Loans">
                        <field name="loan_ids" nolabel="1" context="{'default_employee_id': id}">
                            <list decoration-muted="state in ('refused', 'cancelled', 'completed')" decoration-success="state == 'approved'">
                                <field name="name"/>
                                <field name="loan_type_id"/>
                                <field name="principal_amount"/>
                                <field name="remaining_amount"/>
                                <field name="monthly_installment"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>
                    <group string="Savings &amp; Other Deductions">
                        <field name="deduction_ids" nolabel="1" context="{'default_employee_id': id}">
                            <list editable="bottom">
                                <field name="name"/>
                                <field name="deduction_type"/>
                                <field name="penalty_percentage" optional="show"/>
                                <field name="monthly_amount"/>
                                <field name="start_date"/>
                                <field name="end_date" optional="hide"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>