<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit hr.contract form view to add pay_group_id and cost_center_id -->
    <record id="hr_contract_form_inherit_ahadu" model="ir.ui.view">
        <field name="name">hr.contract.form.inherit.ahadu</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form" />
        <field name="arch" type="xml">
            <!-- Add Cost Center and Pay Group fields after department_id -->
            <xpath expr="//field[@name='department_id']" position="after">
                <field name="pay_group_id" />
                <field name="fuel_liters" />
            </xpath>
        </field>
    </record>
</odoo>
