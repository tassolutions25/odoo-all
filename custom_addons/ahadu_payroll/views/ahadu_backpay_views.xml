<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Backpay Batch List View -->
    <record id="view_ahadu_backpay_batch_tree" model="ir.ui.view">
        <field name="name">ahadu.backpay.batch.tree</field>
        <field name="model">ahadu.backpay.batch</field>
        <field name="arch" type="xml">
            <list string="Backpay Batches">
                <field name="name"/>
                <field name="month"/>
                <field name="year"/>
                <field name="date"/>
                <field name="total_net_difference" sum="Total Net Difference"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-warning="state == 'verified'" 
                       decoration-success="state == 'approved'"/>
            </list>
        </field>
    </record>

    <!-- Backpay Batch Form View -->
    <record id="view_ahadu_backpay_batch_form" model="ir.ui.view">
        <field name="name">ahadu.backpay.batch.form</field>
        <field name="model">ahadu.backpay.batch</field>
        <field name="arch" type="xml">
            <form string="Backpay Batch">
                <header>
                    <button name="action_generate_lines" string="Generate Lines" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_calculate" string="Calculate" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_verify" string="Verify" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_approve" string="Approve" type="object" invisible="state != 'verified'" class="btn-success" groups="payroll.group_payroll_manager"/>
                    <button name="action_draft" string="Set to Draft" type="object" invisible="state in ('draft', 'approved')"/>
                    
                    <!-- REPORTS -->
                    <button name="action_print_excel" string="Export Excel (Preview)" type="object" class="btn-secondary" invisible="state == 'draft'"/>
                    <button name="action_print_tax_declaration" string="Tax Declaration" type="object" class="btn-secondary" invisible="state != 'approved'"/>
                    <button name="action_print_pension_report" string="Pension Report" type="object" class="btn-secondary" invisible="state != 'approved'"/>
                    <button name="action_print_bank_transfer" string="Bank Transfer" type="object" class="btn-success" invisible="state != 'approved' or bank_transfer_done" groups="payroll.group_payroll_manager"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,verified,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Backpay March 2026" readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="month" readonly="state != 'draft'"/>
                            <field name="year" readonly="state != 'draft'"/>
                            <field name="bank_transfer_done" readonly="1" invisible="not bank_transfer_done"/>
                        </group>
                        <group>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="total_net_difference" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Employee Backpay Details">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list create="0">
                                    <field name="employee_id"/>
                                    <field name="effective_date" optional="show"/>
                                    <field name="payslip_id" string="Payslip Month" optional="show"/>
                                    <field name="ctc_id" optional="hide"/>
                                    <field name="promotion_id" optional="show"/>
                                    <field name="old_basic" optional="show"/>
                                    <field name="new_basic" optional="show"/>
                                    <field name="diff_basic" sum="Total Basic Diff"/>
                                    <field name="old_net" optional="show"/>
                                    <field name="new_net" optional="show"/>
                                    <field name="diff_net" sum="Total Net Diff"/>
                                    <field name="diff_tax" sum="Total Tax Diff" optional="hide"/>
                                </list>
                                <form>
                                    <group>
                                        <group string="Employee Info">
                                            <field name="employee_id"/>
                                            <field name="joining_date"/>
                                            <field name="bank_account"/>
                                            <field name="effective_date"/>
                                            <field name="payslip_id"/>
                                            <field name="ctc_id" invisible="not ctc_id"/>
                                            <field name="promotion_id" invisible="not promotion_id"/>
                                        </group>
                                    </group>
                                    <div class="row">
                                        <div class="col-md-4">
                                            <group string="Old Values">
                                                <field name="old_basic"/>
                                                <field name="old_transport"/>
                                                <field name="old_housing"/>
                                                <field name="old_mobile"/>
                                                <field name="old_representation"/>
                                                <field name="old_hardship"/>
                                                <field name="old_ot"/>
                                                <field name="old_gross"/>
                                                <field name="old_income_tax"/>
                                                <field name="old_pension_emp"/>
                                                <field name="old_cost_sharing"/>
                                                <field name="old_net"/>
                                            </group>
                                        </div>
                                        <div class="col-md-4">
                                            <group string="New Values">
                                                <field name="new_basic"/>
                                                <field name="new_transport"/>
                                                <field name="new_housing"/>
                                                <field name="new_mobile"/>
                                                <field name="new_representation"/>
                                                <field name="new_hardship"/>
                                                <field name="new_ot"/>
                                                <field name="new_gross"/>
                                                <field name="new_income_tax"/>
                                                <field name="new_pension_emp"/>
                                                <field name="new_cost_sharing"/>
                                                <field name="new_net"/>
                                            </group>
                                        </div>
                                        <div class="col-md-4">
                                            <group string="Difference">
                                                <field name="diff_basic"/>
                                                <field name="diff_transport"/>
                                                <field name="diff_housing"/>
                                                <field name="diff_mobile"/>
                                                <field name="diff_representation"/>
                                                <field name="diff_hardship"/>
                                                <field name="diff_taxable_gross"/>
                                                <field name="diff_tax"/>
                                                <field name="diff_pension_emp"/>
                                                <field name="diff_cost_sharing"/>
                                                <field name="diff_net"/>
                                            </group>
                                        </div>
                                    </div>
                                </form>
                            </field>
                        </page>
                    </notebook>
                    
                    <group string="Signatures &amp; Accountability">
                        <group>
                            <field name="prepared_by_id"/>
                            <field name="prepared_on"/>
                        </group>
                        <group>
                            <field name="verified_by_id" invisible="not verified_by_id"/>
                            <field name="verified_on" invisible="not verified_on"/>
                        </group>
                        <group>
                            <field name="approved_by_id" invisible="not approved_by_id"/>
                            <field name="approved_on" invisible="not approved_on"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ahadu_backpay_batch" model="ir.actions.act_window">
        <field name="name">Backpay Batches</field>
        <field name="res_model">ahadu.backpay.batch</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Backpay Batch
            </p>
        </field>
    </record>

    <!-- Menu Item (Under Operations) -->
    <menuitem id="menu_ahadu_backpay_batch"
              name="Backpay"
              parent="ahadu_payroll.menu_ahadu_operations"
              action="action_ahadu_backpay_batch"
              sequence="30" />
</odoo>
