<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================== -->
    <!-- 1. VIEWS FOR CUSTOM MODELS                 -->
    <!-- ========================================== -->
    <record id="view_ahadu_account_tree" model="ir.ui.view">
        <field name="name">ahadu.account.list</field>
        <field name="model">ahadu.account</field>
        <field name="arch" type="xml">
            <list>
                <field name="code" />
                <field name="name" />
            </list>
        </field>
    </record>

    <record id="view_ahadu_account_form" model="ir.ui.view">
        <field name="name">ahadu.account.form</field>
        <field name="model">ahadu.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code" />
                        <field name="name" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Pay Group Views -->
    <record id="view_ahadu_pay_group_tree" model="ir.ui.view">
        <field name="name">ahadu.pay.group.list</field>
        <field name="model">ahadu.pay.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="code" />
                <field name="name" />
            </list>
        </field>
    </record>

    <record id="view_ahadu_pay_group_form" model="ir.ui.view">
        <field name="name">ahadu.pay.group.form</field>
        <field name="model">ahadu.pay.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code" />
                        <field name="name" />
                        <field name="job_ids" widget="many2many_tags" options="{'no_create': True}" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================================== -->
    <!-- 2. ACTIONS FOR CUSTOM CONFIG MODELS        -->
    <!-- ========================================== -->
    <record id="action_ahadu_account" model="ir.actions.act_window">
        <field name="name">Payroll Accounts</field>
        <field name="res_model">ahadu.account</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_ahadu_pay_group" model="ir.actions.act_window">
        <field name="name">Pay Groups</field>
        <field name="res_model">ahadu.pay.group</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Region Fuel Tax Deduction Config Views -->
    <record id="view_ahadu_payroll_region_config_tree" model="ir.ui.view">
        <field name="name">ahadu.payroll.region.config.list</field>
        <field name="model">ahadu.payroll.region.config</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="region_id" />
                <field name="transport_allowance_exemption" />
            </list>
        </field>
    </record>

    <record id="view_ahadu_payroll_region_config_form" model="ir.ui.view">
        <field name="name">ahadu.payroll.region.config.form</field>
        <field name="model">ahadu.payroll.region.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Region">
                            <field name="region_id" />
                        </group>
                        <group string="Tax Exemptions">
                            <field name="transport_allowance_exemption" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ahadu_payroll_region_config" model="ir.actions.act_window">
        <field name="name">Region Fuel Tax Deduction Config</field>
        <field name="res_model">ahadu.payroll.region.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure region-specific payroll rules
            </p>
            <p>Define transport allowance exemptions for each region.</p>
        </field>
    </record>

    <!-- ========================================== -->
    <!-- 3. ACTIONS FOR STANDARD PAYROLL MODELS     -->
    <!-- ========================================== -->

    <!-- Configuration Actions -->
    <record id="action_ahadu_structure_standard" model="ir.actions.act_window">
        <field name="name">Salary Structures</field>
        <field name="res_model">hr.payroll.structure</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_ahadu_rule_standard" model="ir.actions.act_window">
        <field name="name">Salary Rules</field>
        <field name="res_model">hr.salary.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Operational Actions (Payslips & Batches) -->
    <record id="action_ahadu_payslip" model="ir.actions.act_window">
        <field name="name">Employee Payslips</field>
        <field name="res_model">hr.payslip</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_ahadu_payslip_run" model="ir.actions.act_window">
        <field name="name">Payslip Batches</field>
        <field name="res_model">hr.payslip.run</field>
        <field name="view_mode">list,form</field>
    </record>


